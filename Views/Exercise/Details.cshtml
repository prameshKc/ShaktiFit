@model FitForgeAI.Models.Exercise
@using FitForgeAI.Services
@{
    var ex    = Model;
    var apiEx = ViewBag.ApiExercise as WorkoutApiExercise;
    ViewBag.Title     = $"{ex.Name} – ShaktiFit";
    ViewBag.ActiveNav = "exercise";
    var lang = Context.Session.GetString("Lang") ?? "en";
    bool ne  = lang == "ne";
    var isAuth = Context.Session.GetString("UserId") != null;
    if (!isAuth) { ViewBag.IsLanding = true; }

    // Build muscle sets from API data (or fallback)
    var primaryMuscles   = apiEx?.PrimaryMuscles   ?? new List<WorkoutApiMuscle>();
    var secondaryMuscles = apiEx?.SecondaryMuscles ?? new List<WorkoutApiMuscle>();

    // Muscle → SVG path id map (matches the SVG below)
    var muscleToSvg = new Dictionary<string, string[]>(StringComparer.OrdinalIgnoreCase)
    {
        ["TRAPEZIUS"]   = new[]{"svg-trapezius-f","svg-trapezius-b"},
        ["SHOULDERS"]   = new[]{"svg-shoulders-l","svg-shoulders-r"},
        ["CHEST"]       = new[]{"svg-chest"},
        ["BACK"]        = new[]{"svg-back-upper","svg-back-lower"},
        ["BICEPS"]      = new[]{"svg-biceps-l","svg-biceps-r"},
        ["TRICEPS"]     = new[]{"svg-triceps-l","svg-triceps-r"},
        ["FOREARMS"]    = new[]{"svg-forearms-l","svg-forearms-r"},
        ["ABS"]         = new[]{"svg-abs"},
        ["OBLIQUES"]    = new[]{"svg-obliques-l","svg-obliques-r"},
        ["GLUTES"]      = new[]{"svg-glutes"},
        ["QUADRICEPS"]  = new[]{"svg-quads-l","svg-quads-r"},
        ["HAMSTRINGS"]  = new[]{"svg-hamstrings-l","svg-hamstrings-r"},
        ["ABDUCTORS"]   = new[]{"svg-abductors-l","svg-abductors-r"},
        ["ADDUCTORS"]   = new[]{"svg-adductors-l","svg-adductors-r"},
        ["CALVES"]      = new[]{"svg-calves-l","svg-calves-r"},
    };

    // Build highlight map: svgId → color
    var highlights = new Dictionary<string, (string color, bool isPrimary)>();
    foreach (var m in primaryMuscles)
    {
        if (muscleToSvg.TryGetValue(m.Code, out var ids))
            foreach (var id in ids)
                highlights[id] = (m.Color, true);
    }
    foreach (var m in secondaryMuscles)
    {
        if (muscleToSvg.TryGetValue(m.Code, out var ids))
            foreach (var id in ids)
                if (!highlights.ContainsKey(id))
                    highlights[id] = (m.Color, false);
    }

    string GetFill(string svgId, string def = "#e2e8f0") =>
        highlights.TryGetValue(svgId, out var h) ? h.color : def;
    string GetOpacity(string svgId) =>
        highlights.ContainsKey(svgId)
            ? (highlights[svgId].isPrimary ? "1" : "0.5")
            : "0.18";

    // Steps
    var steps = ex.Instructions.Count > 0 ? ex.Instructions
              : ex.Description.Split(new[]{ ". " }, StringSplitOptions.RemoveEmptyEntries)
                              .Select(s => s.Trim().TrimEnd('.') + ".")
                              .Where(s => s.Length > 3)
                              .ToList();

    string DiffColor(string d) => d switch {
        "Beginner"     => "#22c55e",
        "Advanced"     => "#ef4444",
        _              => "#f59e0b"
    };
    string DiffBg(string d) => d switch {
        "Beginner"     => "#f0fdf4",
        "Advanced"     => "#fef2f2",
        _              => "#fefce8"
    };
}

<style>
.exd { background:#f8faf8; min-height:100vh; }
.exd-wrap { max-width:1100px; margin:0 auto; padding:24px 20px 80px; }

/* Hero */
.exd-hero {
  background:linear-gradient(135deg,#0f1f0f 0%,#1a3a1a 55%,#16a34a 100%);
  border-radius:20px; padding:30px 34px 26px; margin-bottom:24px;
  position:relative; overflow:hidden;
}
.exd-hero::before { content:''; position:absolute; top:-40px; right:-40px; width:200px; height:200px; background:rgba(34,197,94,0.1); border-radius:50%; }
.exd-back { display:inline-flex; align-items:center; gap:6px; color:rgba(240,253,244,0.6); font-size:13px; font-weight:600; text-decoration:none; margin-bottom:16px; transition:color .15s; }
.exd-back:hover { color:#4ade80; }
.exd-code { display:inline-flex; align-items:center; gap:6px; padding:4px 12px; background:rgba(34,197,94,0.18); border:1px solid rgba(34,197,94,0.3); border-radius:999px; font-size:10px; font-weight:800; color:#86efac; letter-spacing:0.1em; margin-bottom:10px; }
.exd-name { font-size:30px; font-weight:900; color:#f0fdf4; letter-spacing:-0.03em; margin-bottom:8px; line-height:1.15; }
.exd-badges { display:flex; gap:8px; flex-wrap:wrap; }
.exd-badge { padding:5px 13px; border-radius:999px; font-size:12px; font-weight:700; }

/* Layout */
.exd-layout { display:grid; grid-template-columns:340px 1fr; gap:20px; align-items:start; }

/* Muscle Diagram Card */
.exd-muscle-card { background:#ffffff; border:1.5px solid rgba(0,0,0,0.08); border-radius:18px; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,0.05); }
.exd-muscle-title { padding:16px 18px 12px; border-bottom:1px solid rgba(0,0,0,0.06); font-size:13px; font-weight:800; color:#0f172a; display:flex; align-items:center; gap:8px; }
.exd-body-wrap { display:flex; gap:8px; justify-content:center; padding:20px 16px 12px; background:#fafbff; }
.exd-body-label { font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#94a3b8; text-align:center; margin-bottom:4px; }

/* Muscle legend */
.exd-legend { padding:12px 18px 18px; }
.exd-legend-title { font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:0.08em; color:#94a3b8; margin-bottom:10px; }
.exd-muscle-chip { display:inline-flex; align-items:center; gap:6px; padding:5px 11px; border-radius:999px; font-size:12px; font-weight:700; margin:3px; }
.exd-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }

/* Info cards */
.exd-right { display:flex; flex-direction:column; gap:16px; }
.exd-card { background:#ffffff; border:1.5px solid rgba(0,0,0,0.08); border-radius:18px; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,0.05); }
.exd-card-head { padding:14px 20px; border-bottom:1px solid rgba(0,0,0,0.06); font-size:14px; font-weight:800; color:#0f172a; display:flex; align-items:center; gap:8px; }
.exd-card-body { padding:16px 20px; }

/* Steps */
.exd-step { display:flex; align-items:flex-start; gap:14px; padding:12px 0; border-bottom:1px solid rgba(0,0,0,0.05); }
.exd-step:last-child { border-bottom:none; }
.exd-step-num { width:28px; height:28px; background:linear-gradient(135deg,#22c55e,#16a34a); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:800; color:#fff; flex-shrink:0; margin-top:1px; }
.exd-step-text { font-size:14px; color:#374151; line-height:1.65; padding-top:3px; }

/* Stats row */
.exd-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; }
.exd-stat { text-align:center; background:#f8faf8; border-radius:12px; padding:14px 10px; }
.exd-stat-val { font-size:22px; font-weight:900; color:#0f172a; line-height:1; }
.exd-stat-lbl { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:#94a3b8; margin-top:4px; }

/* Pills */
.exd-pills { display:flex; flex-wrap:wrap; gap:7px; }
.exd-pill { padding:6px 14px; border-radius:999px; font-size:12px; font-weight:700; }

@@media(max-width:768px){
  .exd-layout { grid-template-columns:1fr; }
  .exd-name { font-size:22px; }
  .exd-wrap { padding:16px 14px 100px; }
  .exd-stats { grid-template-columns:repeat(3,1fr); }
}
</style>

<div class="exd">
<div class="exd-wrap">

  <!-- Hero -->
  <div class="exd-hero">
    <a href="/Exercise" class="exd-back">← @(ne?"व्यायाम पुस्तकालय":"Exercise Library")</a>
    <div class="exd-code">🏋️ @(apiEx?.Code ?? ex.Category.ToUpper())</div>
    <div class="exd-name">@ex.Name</div>
    <div class="exd-badges">
      <span class="exd-badge" style="background:@DiffBg(ex.Difficulty);color:@DiffColor(ex.Difficulty)">@ex.Difficulty</span>
      @if (ex.IsCompound) {
      <span class="exd-badge" style="background:rgba(34,197,94,0.18);color:#86efac">⚡ Compound</span>
      }
      @foreach (var t in (apiEx?.Types ?? new List<WorkoutApiType>()))
      {<span class="exd-badge" style="background:rgba(255,255,255,0.1);color:rgba(240,253,244,0.75)">@t.Name</span>}
      @foreach (var c in (apiEx?.Categories ?? new List<WorkoutApiCategory>()))
      {<span class="exd-badge" style="background:rgba(255,255,255,0.08);color:rgba(240,253,244,0.6)">@c.Name</span>}
    </div>
  </div>

  <div class="exd-layout">

    <!-- LEFT: Muscle Diagram -->
    <div>
      <div class="exd-muscle-card">
        <div class="exd-muscle-title">🎨 @(ne?"व्यायाम चित्रण":"Exercise Illustration")</div>

        @if (apiEx != null)
        {
        <!-- Real SVG illustration from WorkoutAPI -->
        <div style="background:linear-gradient(135deg,#f8faf8,#f0fdf4);border-bottom:1px solid rgba(0,0,0,0.06);padding:20px 16px;display:flex;justify-content:center;align-items:center;min-height:260px;position:relative">
          <img id="ex-svg-img" src="/Exercise/Image/@apiEx.Id"
               alt="@ex.Name"
               style="max-width:100%;max-height:260px;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(0,0,0,0.12))"
               onerror="this.style.display='none';document.getElementById('body-diagram').style.display='block'" />
          <div style="position:absolute;bottom:8px;right:12px;font-size:9px;color:#94a3b8;font-weight:600">WorkoutAPI</div>
        </div>
        }

        <!-- Body diagram (shown when no API image or as fallback) -->
        <div id="body-diagram" @(apiEx != null ? "style=\"display:none\"" : "")>
        <div class="exd-body-wrap">
          <!-- FRONT VIEW -->
          <div>
            <div class="exd-body-label">Front</div>
            <svg viewBox="0 0 120 280" width="110" xmlns="http://www.w3.org/2000/svg" style="display:block">
              <!-- Head -->
              <ellipse cx="60" cy="18" rx="14" ry="16" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="1"/>
              <!-- Neck -->
              <rect x="54" y="33" width="12" height="10" rx="3" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="1"/>
              <!-- Shoulders -->
              <ellipse id="svg-shoulders-l" cx="30" cy="52" rx="13" ry="9" fill="@GetFill("svg-shoulders-l")" opacity="@GetOpacity("svg-shoulders-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <ellipse id="svg-shoulders-r" cx="90" cy="52" rx="13" ry="9" fill="@GetFill("svg-shoulders-r")" opacity="@GetOpacity("svg-shoulders-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Chest -->
              <path id="svg-chest" d="M43 48 Q60 62 77 48 L77 72 Q60 78 43 72 Z" fill="@GetFill("svg-chest")" opacity="@GetOpacity("svg-chest")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Trapezius (front visible) -->
              <path id="svg-trapezius-f" d="M46 44 Q60 50 74 44 L74 48 Q60 52 46 48 Z" fill="@GetFill("svg-trapezius-f")" opacity="@GetOpacity("svg-trapezius-f")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Abs -->
              <rect id="svg-abs" x="49" y="74" width="22" height="34" rx="5" fill="@GetFill("svg-abs")" opacity="@GetOpacity("svg-abs")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Obliques -->
              <path id="svg-obliques-l" d="M43 72 L49 74 L49 108 L38 100 Z" fill="@GetFill("svg-obliques-l")" opacity="@GetOpacity("svg-obliques-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <path id="svg-obliques-r" d="M77 72 L71 74 L71 108 L82 100 Z" fill="@GetFill("svg-obliques-r")" opacity="@GetOpacity("svg-obliques-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Upper arms (biceps) -->
              <rect id="svg-biceps-l" x="18" y="55" width="10" height="36" rx="5" fill="@GetFill("svg-biceps-l")" opacity="@GetOpacity("svg-biceps-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <rect id="svg-biceps-r" x="92" y="55" width="10" height="36" rx="5" fill="@GetFill("svg-biceps-r")" opacity="@GetOpacity("svg-biceps-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Forearms -->
              <rect id="svg-forearms-l" x="14" y="93" width="10" height="32" rx="4" fill="@GetFill("svg-forearms-l")" opacity="@GetOpacity("svg-forearms-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <rect id="svg-forearms-r" x="96" y="93" width="10" height="32" rx="4" fill="@GetFill("svg-forearms-r")" opacity="@GetOpacity("svg-forearms-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Torso -->
              <rect x="43" y="48" width="34" height="62" rx="6" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8" style="z-index:-1"/>
              <!-- Adductors -->
              <path id="svg-adductors-l" d="M49 112 L60 118 L57 155 L46 148 Z" fill="@GetFill("svg-adductors-l")" opacity="@GetOpacity("svg-adductors-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <path id="svg-adductors-r" d="M71 112 L60 118 L63 155 L74 148 Z" fill="@GetFill("svg-adductors-r")" opacity="@GetOpacity("svg-adductors-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Quads -->
              <path id="svg-quads-l" d="M40 112 L50 112 L54 152 L38 148 Z" fill="@GetFill("svg-quads-l")" opacity="@GetOpacity("svg-quads-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <path id="svg-quads-r" d="M80 112 L70 112 L66 152 L82 148 Z" fill="@GetFill("svg-quads-r")" opacity="@GetOpacity("svg-quads-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Abductors -->
              <path id="svg-abductors-l" d="M36 112 L42 112 L40 148 L32 140 Z" fill="@GetFill("svg-abductors-l")" opacity="@GetOpacity("svg-abductors-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <path id="svg-abductors-r" d="M84 112 L78 112 L80 148 L88 140 Z" fill="@GetFill("svg-abductors-r")" opacity="@GetOpacity("svg-abductors-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Knees -->
              <ellipse cx="46" cy="156" rx="10" ry="8" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8"/>
              <ellipse cx="74" cy="156" rx="10" ry="8" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Calves (front) -->
              <path id="svg-calves-l" d="M36 164 L56 164 L54 205 L38 205 Z" fill="@GetFill("svg-calves-l")" opacity="@GetOpacity("svg-calves-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <path id="svg-calves-r" d="M64 164 L84 164 L82 205 L66 205 Z" fill="@GetFill("svg-calves-r")" opacity="@GetOpacity("svg-calves-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Feet -->
              <ellipse cx="46" cy="208" rx="10" ry="5" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8"/>
              <ellipse cx="74" cy="208" rx="10" ry="5" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Hands -->
              <ellipse cx="19" cy="127" rx="7" ry="5" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8"/>
              <ellipse cx="101" cy="127" rx="7" ry="5" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8"/>
            </svg>
          </div>

          <!-- BACK VIEW -->
          <div>
            <div class="exd-body-label">Back</div>
            <svg viewBox="0 0 120 280" width="110" xmlns="http://www.w3.org/2000/svg" style="display:block">
              <!-- Head -->
              <ellipse cx="60" cy="18" rx="14" ry="16" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="1"/>
              <!-- Neck -->
              <rect x="54" y="33" width="12" height="10" rx="3" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="1"/>
              <!-- Shoulders (back) -->
              <ellipse cx="30" cy="52" rx="13" ry="9" fill="@GetFill("svg-shoulders-l")" opacity="@GetOpacity("svg-shoulders-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <ellipse cx="90" cy="52" rx="13" ry="9" fill="@GetFill("svg-shoulders-r")" opacity="@GetOpacity("svg-shoulders-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Trapezius (back) -->
              <path id="svg-trapezius-b" d="M44 43 Q60 56 76 43 L77 72 Q60 66 43 72 Z" fill="@GetFill("svg-trapezius-b")" opacity="@GetOpacity("svg-trapezius-b")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Upper back -->
              <path id="svg-back-upper" d="M43 48 Q60 54 77 48 L77 80 Q60 86 43 80 Z" fill="@GetFill("svg-back-upper")" opacity="@GetOpacity("svg-back-upper")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Lower back -->
              <path id="svg-back-lower" d="M43 80 Q60 86 77 80 L77 112 Q60 112 43 112 Z" fill="@GetFill("svg-back-lower")" opacity="@GetOpacity("svg-back-lower")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Triceps -->
              <rect id="svg-triceps-l" x="18" y="55" width="10" height="36" rx="5" fill="@GetFill("svg-triceps-l")" opacity="@GetOpacity("svg-triceps-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <rect id="svg-triceps-r" x="92" y="55" width="10" height="36" rx="5" fill="@GetFill("svg-triceps-r")" opacity="@GetOpacity("svg-triceps-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Forearms back -->
              <rect x="14" y="93" width="10" height="32" rx="4" fill="@GetFill("svg-forearms-l")" opacity="@GetOpacity("svg-forearms-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <rect x="96" y="93" width="10" height="32" rx="4" fill="@GetFill("svg-forearms-r")" opacity="@GetOpacity("svg-forearms-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Glutes -->
              <path id="svg-glutes" d="M43 112 Q60 122 77 112 L77 135 Q60 140 43 135 Z" fill="@GetFill("svg-glutes")" opacity="@GetOpacity("svg-glutes")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Hamstrings -->
              <path id="svg-hamstrings-l" d="M40 135 L56 133 L54 168 L38 168 Z" fill="@GetFill("svg-hamstrings-l")" opacity="@GetOpacity("svg-hamstrings-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <path id="svg-hamstrings-r" d="M80 135 L64 133 L66 168 L82 168 Z" fill="@GetFill("svg-hamstrings-r")" opacity="@GetOpacity("svg-hamstrings-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Calves back -->
              <path x="36" d="M37 172 L57 172 L55 210 L39 210 Z" fill="@GetFill("svg-calves-l")" opacity="@GetOpacity("svg-calves-l")" stroke="#cbd5e1" stroke-width="0.8"/>
              <path d="M63 172 L83 172 L81 210 L65 210 Z" fill="@GetFill("svg-calves-r")" opacity="@GetOpacity("svg-calves-r")" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Knees back -->
              <ellipse cx="46" cy="170" rx="10" ry="8" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8"/>
              <ellipse cx="74" cy="170" rx="10" ry="8" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Feet -->
              <ellipse cx="46" cy="212" rx="10" ry="5" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8"/>
              <ellipse cx="74" cy="212" rx="10" ry="5" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8"/>
              <!-- Hands -->
              <ellipse cx="19" cy="127" rx="7" ry="5" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8"/>
              <ellipse cx="101" cy="127" rx="7" ry="5" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="0.8"/>
            </svg>
          </div>
        </div>
        </div><!-- /body-diagram -->

        <!-- Legend -->
        <div class="exd-legend">
          @if (primaryMuscles.Any())
          {
          <div class="exd-legend-title">🎯 @(ne?"मुख्य मांसपेशी":"Primary Muscles")</div>
          <div style="margin-bottom:10px">
            @foreach (var m in primaryMuscles)
            {
            <span class="exd-muscle-chip" style="background:@m.Color;color:#fff;box-shadow:0 2px 8px @(m.Color)55">
              <span class="exd-dot" style="background:#ffffff55"></span>@m.Name
            </span>
            }
          </div>
          }
          @if (secondaryMuscles.Any())
          {
          <div class="exd-legend-title" style="margin-top:6px">↗ @(ne?"सहायक मांसपेशी":"Secondary Muscles")</div>
          <div>
            @foreach (var m in secondaryMuscles)
            {
            <span class="exd-muscle-chip" style="background:@(m.Color)22;color:@m.Color;border:1px solid @(m.Color)44">
              <span class="exd-dot" style="background:@m.Color"></span>@m.Name
            </span>
            }
          </div>
          }
          @if (!primaryMuscles.Any() && ex.TargetMuscles.Any())
          {
          <div class="exd-legend-title">💪 @(ne?"मांसपेशी":"Muscles")</div>
          @foreach (var m in ex.TargetMuscles)
          {<span class="exd-muscle-chip" style="background:#f0fdf4;color:#16a34a;border:1px solid rgba(34,197,94,0.2)"><span class="exd-dot" style="background:#22c55e"></span>@m</span>}
          }

          <!-- Legend key -->
          <div style="margin-top:14px;padding-top:12px;border-top:1px solid rgba(0,0,0,0.06);display:flex;gap:14px;font-size:11px;color:#64748b">
            <span style="display:flex;align-items:center;gap:5px"><span style="width:12px;height:12px;border-radius:2px;background:#22c55e;display:inline-block"></span>@(ne?"मुख्य":"Primary")</span>
            <span style="display:flex;align-items:center;gap:5px"><span style="width:12px;height:12px;border-radius:2px;background:#94a3b8;opacity:0.5;display:inline-block"></span>@(ne?"सहायक":"Secondary")</span>
            <span style="display:flex;align-items:center;gap:5px"><span style="width:12px;height:12px;border-radius:2px;background:#e2e8f0;display:inline-block"></span>@(ne?"निष्क्रिय":"Inactive")</span>
          </div>
        </div>
      </div>

      <!-- Stats Card -->
      <div class="exd-card" style="margin-top:16px">
        <div class="exd-card-head">📊 @(ne?"व्यायाम तथ्याङ्क":"Exercise Stats")</div>
        <div class="exd-card-body">
          <div class="exd-stats">
            <div class="exd-stat">
              <div class="exd-stat-val" style="color:#22c55e">@ex.DefaultSets</div>
              <div class="exd-stat-lbl">@(ne?"सेट":"Sets")</div>
            </div>
            <div class="exd-stat">
              <div class="exd-stat-val" style="color:#3b82f6">@ex.DefaultReps</div>
              <div class="exd-stat-lbl">@(ne?"पुनरावृत्ति":"Reps")</div>
            </div>
            <div class="exd-stat">
              <div class="exd-stat-val" style="color:#f59e0b">@ex.RestSeconds<span style="font-size:12px">s</span></div>
              <div class="exd-stat-lbl">@(ne?"आराम":"Rest")</div>
            </div>
          </div>

          @if (ex.Equipment.Any())
          {
          <div style="margin-top:14px">
            <div style="font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;color:#94a3b8;margin-bottom:8px">🏋️ @(ne?"उपकरण":"Equipment")</div>
            <div class="exd-pills">
              @foreach (var eq in ex.Equipment)
              {<span class="exd-pill" style="background:#f1f5f9;color:#475569;border:1px solid rgba(0,0,0,0.08)">@eq</span>}
            </div>
          </div>
          }

          @if (apiEx?.Types.Any() == true)
          {
          <div style="margin-top:12px">
            <div style="font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;color:#94a3b8;margin-bottom:8px">⚡ @(ne?"आन्दोलन प्रकार":"Movement Type")</div>
            <div class="exd-pills">
              @foreach (var t in apiEx.Types)
              {
              bool isCompound = t.Code == "POLYARTICULAR";
              <span class="exd-pill" style="background:@(isCompound?"#f0fdf4":"#eff6ff");color:@(isCompound?"#16a34a":"#2563eb");border:1px solid @(isCompound?"rgba(34,197,94,0.2)":"rgba(37,99,235,0.2)")">
                @(isCompound?"⚡ Compound":"🎯 Isolation")
              </span>
              }
            </div>
          </div>
          }
        </div>
      </div>
    </div>

    <!-- RIGHT: Instructions + Info -->
    <div class="exd-right">

      <!-- Step-by-step instructions -->
      <div class="exd-card">
        <div class="exd-card-head">📋 @(ne?"चरण-दर-चरण निर्देशनहरू":"Step-by-Step Instructions")</div>
        <div class="exd-card-body" style="padding:12px 20px 16px">
          @if (steps.Any())
          {
          @for (int i = 0; i < steps.Count; i++)
          {
          <div class="exd-step">
            <div class="exd-step-num">@(i+1)</div>
            <div class="exd-step-text">@steps[i]</div>
          </div>
          }
          }
          else
          {
          <p style="color:#64748b;font-size:14px;line-height:1.7">@ex.Description</p>
          }
        </div>
      </div>

      <!-- Common Mistakes -->
      @if (ex.CommonMistakes.Any())
      {
      <div class="exd-card">
        <div class="exd-card-head" style="color:#dc2626">⚠️ @(ne?"सामान्य गल्तीहरू":"Common Mistakes")</div>
        <div class="exd-card-body">
          @foreach (var m in ex.CommonMistakes)
          {
          <div class="exd-step">
            <div style="width:28px;height:28px;background:#fef2f2;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0">⚠️</div>
            <div class="exd-step-text">@m</div>
          </div>
          }
        </div>
      </div>
      }

      <!-- Pro Tips -->
      @if (ex.Tips.Any())
      {
      <div class="exd-card">
        <div class="exd-card-head" style="color:#16a34a">💡 @(ne?"प्रो सुझावहरू":"Pro Tips")</div>
        <div class="exd-card-body">
          @foreach (var tip in ex.Tips)
          {
          <div class="exd-step">
            <div style="width:28px;height:28px;background:#f0fdf4;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0">💡</div>
            <div class="exd-step-text">@tip</div>
          </div>
          }
        </div>
      </div>
      }

      <!-- Similar exercises -->
      <div class="exd-card">
        <div class="exd-card-head">🔄 @(ne?"समान व्यायाम खोज्नुहोस्":"Explore More Exercises")</div>
        <div class="exd-card-body">
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <a href="/Exercise?category=@Uri.EscapeDataString(ex.Category)" style="padding:10px 20px;background:#f0fdf4;border:1.5px solid rgba(34,197,94,0.25);border-radius:12px;color:#16a34a;font-weight:700;font-size:13px;text-decoration:none">
              💪 @(ne?"अधिक":"More") @ex.Category @(ne?"व्यायाम":"Exercises")
            </a>
            @if (isAuth) {
            <a href="/Workout/Builder" style="padding:10px 20px;background:linear-gradient(135deg,#22c55e,#16a34a);border-radius:12px;color:#fff;font-weight:700;font-size:13px;text-decoration:none">
              ✏️ @(ne?"योजनामा थप्नुहोस्":"Add to Workout Plan")
            </a>
            }
          </div>
        </div>
      </div>

      <!-- API Source badge -->
      @if (apiEx != null)
      {
      <div style="text-align:right">
        <span style="font-size:10px;color:#94a3b8;font-weight:600">📡 @(ne?"स्रोत":"Source"): WorkoutAPI · @apiEx.Code</span>
      </div>
      }
    </div>

  </div>
</div>
</div>
