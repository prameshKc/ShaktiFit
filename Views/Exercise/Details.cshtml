@model FitForgeAI.Models.Exercise
@{
    var ex = Model;
    ViewBag.Title = $"{ex.Name} – ShaktiFit";
    ViewBag.ActiveNav = "exercise";
    var lang = Context.Session.GetString("Lang") ?? "en";
    bool ne = lang == "ne";
    string ExName() => ne && !string.IsNullOrEmpty(ex.NameNepali) ? ex.NameNepali : ex.Name;
    string ExDesc() => ne && !string.IsNullOrEmpty(ex.DescriptionNepali) ? ex.DescriptionNepali : ex.Description;
}

<div class="page-container">

    <div style="margin-bottom:20px">
        <a href="/Exercise" class="btn btn-ghost btn-sm">← @(ne?"फिर्ता":"Back to Library")</a>
    </div>

    <div style="display:grid;grid-template-columns:2fr 1fr;gap:24px">

        <!-- Main -->
        <div>
            <div class="card" style="margin-bottom:20px">
                <div class="card-body" style="padding:28px">
                    <div style="display:flex;align-items:flex-start;gap:16px;margin-bottom:20px;flex-wrap:wrap">
                        <div style="font-size:60px">💪</div>
                        <div style="flex:1">
                            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px">
                                <span class="diff-badge diff-@ex.Difficulty.ToLower()">@ex.Difficulty</span>
                                <span class="badge badge-gray">@ex.Category</span>
                                @if (ex.IsCompound) { <span class="badge" style="background:var(--amber-bg);color:var(--amber)">⚡ @(ne?"यौगिक":"Compound")</span> }
                            </div>
                            <h1 style="font-size:28px;font-weight:900;margin-bottom:4px">@ExName()</h1>
                            @if (!string.IsNullOrEmpty(ex.NameNepali))
                            { <div style="color:var(--text-muted);font-size:14px">@(ne ? ex.Name : ex.NameNepali)</div> }
                        </div>
                    </div>
                    <p style="color:var(--text-secondary);line-height:1.7">@ExDesc()</p>
                </div>
            </div>

            <!-- Instructions -->
            @if (ex.Instructions.Any())
            {
            <div class="card" style="margin-bottom:20px">
                <div class="card-header"><div class="card-title">📋 @(ne?"निर्देशनहरू":"Instructions")</div></div>
                <div class="card-body">
                    @{ int step = 1; }
                    @foreach (var ins in ex.Instructions)
                    {
                    <div style="display:flex;gap:14px;padding:12px 0;border-bottom:1px solid var(--border)">
                        <div style="width:28px;height:28px;background:var(--indigo);color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0">@(step++)</div>
                        <div style="font-size:14px;line-height:1.6;color:var(--text-secondary)">@ins</div>
                    </div>
                    }
                </div>
            </div>
            }

            <!-- Mistakes & Tips -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                @if (ex.CommonMistakes.Any())
                {
                <div class="card">
                    <div class="card-header"><div class="card-title">⚠️ @(ne?"सामान्य गल्तीहरू":"Common Mistakes")</div></div>
                    <div class="card-body">
                        @foreach (var m in ex.CommonMistakes)
                        {
                        <div style="display:flex;gap:8px;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px">
                            <span style="color:var(--red);flex-shrink:0">✗</span>
                            <span style="color:var(--text-secondary)">@m</span>
                        </div>
                        }
                    </div>
                </div>
                }
                @if (ex.Tips.Any())
                {
                <div class="card">
                    <div class="card-header"><div class="card-title">💡 @(ne?"सुझावहरू":"Pro Tips")</div></div>
                    <div class="card-body">
                        @foreach (var tip in ex.Tips)
                        {
                        <div style="display:flex;gap:8px;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px">
                            <span style="color:var(--green);flex-shrink:0">✓</span>
                            <span style="color:var(--text-secondary)">@tip</span>
                        </div>
                        }
                    </div>
                </div>
                }
            </div>
        </div>

        <!-- Sidebar -->
        <div style="display:flex;flex-direction:column;gap:16px">

            <div class="card">
                <div class="card-header"><div class="card-title">📊 @(ne?"व्यायाम विवरण":"Exercise Details")</div></div>
                <div class="card-body" style="display:flex;flex-direction:column;gap:12px">
                    @{ var equipStr = ex.Equipment.Any() ? string.Join(", ", ex.Equipment) : (ne?"कुनै छैन":"None"); }
                    @foreach (var item in new (string,string)[]{
                        (ne?"सेटहरू":"Sets", $"{ex.DefaultSets}"),
                        (ne?"रेपहरू":"Reps", ex.DefaultReps),
                        (ne?"आराम":"Rest", $"{ex.RestSeconds}s"),
                        (ne?"उपकरण":"Equipment", equipStr)})
                    {
                    <div style="display:flex;justify-content:space-between;font-size:14px;padding:8px 0;border-bottom:1px solid var(--border)">
                        <span style="color:var(--text-muted)">@item.Item1</span>
                        <span style="font-weight:700">@item.Item2</span>
                    </div>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-header"><div class="card-title">💪 @(ne?"लक्षित मांसपेशी":"Target Muscles")</div></div>
                <div class="card-body">
                    <div style="display:flex;flex-wrap:wrap;gap:6px">
                        @foreach (var m in ex.TargetMuscles)
                        { <span class="badge badge-indigo">@m</span> }
                    </div>
                </div>
            </div>

            <a href="/Exercise" class="btn btn-ghost" style="justify-content:center">← @(ne?"पुस्तकालय फिर्ता":"Back to Library")</a>
            @if (Context.Session.GetString("UserId") != null)
            {
            <a href="/Workout" class="btn btn-primary" style="justify-content:center">🏋️ @(ne?"व्यायाम योजना हेर्नुहोस्":"View Workout Plans")</a>
            }
        </div>

    </div>
</div>
