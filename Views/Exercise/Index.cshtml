@section Scripts {
<script>
// ── Tab switcher ──
function switchTab(tab) {
  const isLib = tab === 'library';
  document.getElementById('panel-library').style.display = isLib ? '' : 'none';
  document.getElementById('panel-splits').style.display  = isLib ? 'none' : '';
  const libBtn = document.getElementById('tab-library');
  const splBtn = document.getElementById('tab-splits');
  libBtn.style.background    = isLib ? 'linear-gradient(135deg,#22c55e,#16a34a)' : 'transparent';
  libBtn.style.color         = isLib ? '#fff' : '#16a34a';
  libBtn.style.boxShadow     = isLib ? '0 2px 8px rgba(34,197,94,0.3)' : 'none';
  splBtn.style.background    = isLib ? 'transparent' : 'linear-gradient(135deg,#22c55e,#16a34a)';
  splBtn.style.color         = isLib ? '#16a34a' : '#fff';
  splBtn.style.boxShadow     = isLib ? 'none' : '0 2px 8px rgba(34,197,94,0.3)';
}

// ── Category filter ──
function filterEx(btn) {
  document.querySelectorAll('.ex-filter').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyFilter();
}
// ── Difficulty filter ──
let activeDiff = 'all';
function filterDiff(d, btn) {
  activeDiff = d;
  document.querySelectorAll('.ex-diff-btn').forEach(b => {
    b.style.background = ''; b.style.borderColor = ''; b.style.color = '';
  });
  btn.style.background = 'linear-gradient(135deg,#22c55e,#16a34a)';
  btn.style.borderColor = 'transparent';
  btn.style.color = '#fff';
  applyFilter();
}
// ── Search ──
const searchEl = document.getElementById('exSearch');
if (searchEl) searchEl.addEventListener('input', applyFilter);

function applyFilter() {
  const cat = document.querySelector('.ex-filter.active')?.dataset.cat ?? 'all';
  const q   = (searchEl?.value ?? '').toLowerCase();
  let count = 0;
  document.querySelectorAll('.ex-card').forEach(card => {
    const matchCat  = cat === 'all' || card.dataset.cat === cat;
    const matchQ    = !q || card.dataset.name.includes(q);
    const matchDiff = activeDiff === 'all' || card.dataset.diff === activeDiff;
    const show = matchCat && matchQ && matchDiff;
    card.style.display = show ? '' : 'none';
    if (show) count++;
  });
  document.getElementById('noResult').style.display = count === 0 ? 'block' : 'none';
}

// ── Split card toggle ──
function toggleSplit(id) {
  // all splits are always visible — card click can expand detail if needed
  // For now just a visual ripple / no-collapse behavior
}
</script>
}
