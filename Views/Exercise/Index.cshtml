@model List<FitForgeAI.Models.Exercise>
@{
    ViewBag.Title = "Exercise Library – ShaktiFit";
    ViewBag.ActiveNav = "exercise";
    var isAuth = Context.Session.GetString("UserId") != null;
    if (!isAuth) { ViewBag.IsLanding = true; }
    var lang = Context.Session.GetString("Lang") ?? "en";
    bool ne = lang == "ne";
    var exercises = Model ?? new List<FitForgeAI.Models.Exercise>();
    var categories = (IEnumerable<string>)(ViewBag.Categories ?? new List<string>());

    string CatIcon(string cat) => cat.ToLower() switch {
        "chest"    => "🫸",
        "back"     => "🔙",
        "legs"     => "🦵",
        "shoulders"=> "🤸",
        "arms"     => "💪",
        "core"     => "🧘",
        "cardio"   => "🏃",
        "mobility" => "🙆",
        "full body" or "fullbody" => "⚡",
        _          => "🏋️"
    };
    string CatColor(string cat) => cat.ToLower() switch {
        "chest"    => "#f87171",
        "back"     => "#60a5fa",
        "legs"     => "#4ade80",
        "shoulders"=> "#a78bfa",
        "arms"     => "#f5c542",
        "core"     => "#fb923c",
        "cardio"   => "#34d399",
        "mobility" => "#f472b6",
        _          => "#94a3b8"
    };
}

<div style="min-height:100vh;background:#0d0b09">
<div class="page-container" style="padding:28px 32px">

    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:28px">
        <div>
            <h1 style="font-size:26px;font-weight:900;color:#f5f0e8;letter-spacing:-0.02em;margin-bottom:4px">@(ne?"व्यायाम पुस्तकालय":"Exercise Library")</h1>
            <p style="color:rgba(245,240,232,0.4);font-size:14px">@exercises.Count @(ne?"व्यायामहरू उपलब्ध":"exercises available")</p>
        </div>
        @if (isAuth)
        {
        <a href="/Workout/Builder" style="display:inline-flex;align-items:center;gap:8px;padding:10px 20px;background:#f5c542;color:#1c1917;font-weight:700;font-size:14px;border-radius:10px;text-decoration:none">
            ✏️ @(ne?"कस्टम योजना बनाउनुहोस्":"Build Custom Plan")
        </a>
        }
    </div>

    <!-- Search + Filters -->
    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px;align-items:center">
        <div style="position:relative;flex:1;min-width:200px;max-width:300px">
            <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:rgba(245,240,232,0.3);font-size:14px">🔍</span>
            <input type="text" id="exSearch"
                placeholder="@(ne?"व्यायाम खोज्नुहोस्...":"Search exercises...")"
                style="width:100%;background:#1c1917;border:1px solid rgba(255,255,255,0.1);border-radius:10px;color:#f5f0e8;padding:10px 12px 10px 36px;font-size:14px;font-family:inherit;outline:none" />
        </div>
        <div style="display:flex;gap:6px;flex-wrap:wrap">
            <button class="ex-filter active" data-cat="all" onclick="filterEx(this)" style="padding:7px 16px;background:rgba(245,197,66,0.15);border:1px solid rgba(245,197,66,0.4);border-radius:999px;color:#f5c542;font-size:12px;font-weight:700;cursor:pointer">
                @(ne?"सबै":"All") (@exercises.Count)
            </button>
            @foreach (var cat in categories)
            {
            var cnt = exercises.Count(e => e.Category == cat);
            <button class="ex-filter" data-cat="@cat.ToLower()" onclick="filterEx(this)"
                style="padding:7px 14px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:999px;color:rgba(245,240,232,0.55);font-size:12px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:5px">
                <span>@CatIcon(cat)</span> @cat <span style="color:rgba(245,240,232,0.3)">(@cnt)</span>
            </button>
            }
        </div>
    </div>

    <!-- Grid -->
    <div id="exGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px">
        @foreach (var ex in exercises)
        {
        var icon = CatIcon(ex.Category);
        var color = CatColor(ex.Category);
        <a href="/Exercise/Details/@ex.Id" class="ex-card2" data-cat="@ex.Category.ToLower()" data-name="@ex.Name.ToLower() @(ex.NameNepali?.ToLower())"
           style="background:#131110;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:20px;text-decoration:none;display:block;transition:border-color 0.2s,transform 0.15s;position:relative;overflow:hidden">
            <div style="position:absolute;top:0;left:0;right:0;height:3px;background:@color;opacity:0.7;border-radius:16px 16px 0 0"></div>
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px">
                <div style="width:44px;height:44px;background:@(color)18;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:22px">@icon</div>
                @if (ex.IsCompound) {
                <span style="font-size:10px;font-weight:700;color:#f5c542;background:rgba(245,197,66,0.1);border:1px solid rgba(245,197,66,0.2);border-radius:999px;padding:3px 8px">⚡ @(ne?"यौगिक":"Compound")</span>
                }
            </div>
            <div style="font-size:10px;font-weight:700;color:@color;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px">@ex.Category</div>
            <div style="font-size:15px;font-weight:800;color:#f5f0e8;margin-bottom:3px;letter-spacing:-0.01em">@(ne && !string.IsNullOrEmpty(ex.NameNepali) ? ex.NameNepali : ex.Name)</div>
            @if (!string.IsNullOrEmpty(ex.NameNepali)) {
            <div style="font-size:11px;color:rgba(245,240,232,0.3);margin-bottom:10px">@(ne ? ex.Name : ex.NameNepali)</div>
            }
            <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px">
                <span style="font-size:10px;padding:3px 8px;border-radius:999px;font-weight:700;
                    @(ex.Difficulty == "Beginner" ? "background:rgba(74,222,128,0.12);color:#4ade80;" :
                      ex.Difficulty == "Advanced"  ? "background:rgba(248,113,113,0.12);color:#f87171;" :
                                                     "background:rgba(251,191,36,0.12);color:#fbbf24;")">
                    @ex.Difficulty
                </span>
                @foreach (var m in ex.TargetMuscles.Take(2))
                {<span style="font-size:10px;color:rgba(245,240,232,0.35);padding:3px 8px;background:rgba(255,255,255,0.04);border-radius:999px">@m</span>}
            </div>
            <div style="font-size:11px;color:rgba(245,240,232,0.3);border-top:1px solid rgba(255,255,255,0.05);padding-top:10px">
                @ex.DefaultSets×@ex.DefaultReps · @ex.RestSeconds s @(ne?"आराम":"rest")
            </div>
        </a>
        }
    </div>

    <div id="noResult" style="display:none;text-align:center;padding:80px;color:rgba(245,240,232,0.3)">
        <div style="font-size:48px;margin-bottom:12px">🔍</div>
        <div style="font-size:16px;font-weight:600">@(ne?"कुनै व्यायाम भेटिएन।":"No exercises found.")</div>
    </div>

</div>
</div>

<style>
.ex-card2:hover { border-color:rgba(245,197,66,0.3) !important; transform:translateY(-2px); }
.ex-filter.active { background:rgba(245,197,66,0.15) !important; border-color:rgba(245,197,66,0.4) !important; color:#f5c542 !important; }
</style>

@section Scripts {
<script>
function filterEx(btn) {
    document.querySelectorAll('.ex-filter').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilter();
}
const searchEl = document.getElementById('exSearch');
if (searchEl) searchEl.addEventListener('input', applyFilter);
function applyFilter() {
    const cat = document.querySelector('.ex-filter.active')?.dataset.cat ?? 'all';
    const q = (searchEl?.value ?? '').toLowerCase();
    let count = 0;
    document.querySelectorAll('.ex-card2').forEach(card => {
        const matchCat = cat === 'all' || card.dataset.cat === cat;
        const matchQ = !q || card.dataset.name.includes(q);
        const show = matchCat && matchQ;
        card.style.display = show ? '' : 'none';
        if (show) count++;
    });
    document.getElementById('noResult').style.display = count === 0 ? 'block' : 'none';
}
</script>
}
