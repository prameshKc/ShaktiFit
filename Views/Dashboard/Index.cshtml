@model FitForgeAI.ViewModels.DashboardViewModel
@{ ViewBag.Title = "Dashboard – ShaktiFit"; ViewBag.ActiveNav = "dashboard"; }
@{
    var t = Model.Translations;
    string Tr(string key) => t.ContainsKey(key) ? t[key] : key;
    var pct = Model.WorkoutDaysTarget > 0
        ? Math.Min(100, (int)((double)Model.WeeklyCompleted / Model.WorkoutDaysTarget * 100))
        : 0;
    var user = Model.User;
    var ne = Model.Lang == "ne";
}

<div class="page-container">

    @if (TempData["Success"] != null)
    { <div class="alert alert-success">✅ @TempData["Success"]</div> }
    @if (TempData["EmailSuccess"] != null)
    { <div style="background:#f0fdf4;border:1.5px solid rgba(34,197,94,.3);border-radius:12px;padding:13px 18px;margin-bottom:14px;font-size:14px;font-weight:700;color:#16a34a">@TempData["EmailSuccess"]</div> }
    @if (TempData["EmailError"] != null)
    { <div style="background:#fef2f2;border:1.5px solid rgba(239,68,68,.3);border-radius:12px;padding:13px 18px;margin-bottom:14px;font-size:14px;font-weight:700;color:#dc2626">@TempData["EmailError"]</div> }

    <!-- Welcome Strip -->
    <div class="welcome-strip" style="position:relative">
        <div class="ws-greeting">@(ne?"नमस्ते":"Welcome back"), @user.Name! 👋</div>
        <div class="ws-quote">"@Model.MotivationalQuote"</div>
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-top:14px">
          <div class="ws-streak">🔥 @user.WorkoutStreak @(ne?"दिनको लहर":"day streak")</div>
          <form method="post" action="/Email/SendReminder" style="display:inline">
            @Html.AntiForgeryToken()
            <button type="submit"
              style="padding:8px 16px;background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);border-radius:999px;color:#f0fdf4;font-size:12px;font-weight:700;cursor:pointer;transition:all .15s"
              onmouseover="this.style.background='rgba(255,255,255,0.25)'"
              onmouseout="this.style.background='rgba(255,255,255,0.15)'">
              📧 @(ne?"आजको Reminder पठाउनुहोस्":"Email Today's Workout")
            </button>
          </form>
        </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">🏋️</div>
            <div class="stat-label">@Tr("today_workout")</div>
            <div class="stat-value text-gradient">@(Model.TodaysWorkout?.Type ?? (ne?"आराम":"Rest"))</div>
            <div class="stat-sub">@(Model.TodaysWorkout?.Name ?? (ne?"पुनःप्राप्ति दिन":"Recovery Day"))</div>
        </div>
        <div class="stat-card sc-green">
            <div class="stat-icon">🔥</div>
            <div class="stat-label">@Tr("workout_streak")</div>
            <div class="stat-value" data-counter data-target="@user.WorkoutStreak">0</div>
            <div class="stat-sub">@(ne?"लगातार दिनहरू":"days in a row")</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">✅</div>
            <div class="stat-label">@(ne?"कुल व्यायाम":"Total Workouts")</div>
            <div class="stat-value text-gradient" data-counter data-target="@user.TotalWorkoutsCompleted">0</div>
            <div class="stat-sub">@(ne?"सबै समय":"all time")</div>
        </div>
        <div class="stat-card sc-green">
            <div class="stat-icon">🏃</div>
            <div class="stat-label">@(ne?"साप्ताहिक किमी":"Weekly km")</div>
            <div class="stat-value">@Model.WeeklyMileage.ToString("0.0")</div>
            <div class="stat-sub">@(ne?"यस हप्ता":"this week")</div>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="dash-grid">

        <!-- Today's Workout -->
        <div class="card span2" style="background:#ffffff;border:1.5px solid rgba(0,0,0,0.07)">
            <div class="card-header">
                <div class="card-title">🏋️ @Tr("today_workout")</div>
                @if (Model.TodaysWorkout != null)
                {
                <span class="wt-badge wtb-@(Model.TodaysWorkout.Type.ToLower())">@(ne && !string.IsNullOrEmpty(Model.TodaysWorkout.NameNepali) ? Model.TodaysWorkout.Type : Model.TodaysWorkout.Type)</span>
                }
            </div>
            <div class="card-body">
                @if (Model.TodaysWorkout != null)
                {
                <div style="margin-bottom:18px">
                    <div style="font-size:20px;font-weight:800;margin-bottom:6px">@(ne && !string.IsNullOrEmpty(Model.TodaysWorkout.NameNepali) ? Model.TodaysWorkout.NameNepali : Model.TodaysWorkout.Name)</div>
                    <div style="color:#64748b;font-size:13px">⏱️ @Model.TodaysWorkout.DurationMinutes @(ne?"मिनेट":"min") &nbsp;·&nbsp; 🔥 ~@Model.TodaysWorkout.EstimatedCalories kcal &nbsp;·&nbsp; 💪 @Model.TodaysWorkout.Exercises.Count @(ne?"व्यायाम":"exercises")</div>
                </div>
                <table style="width:100%;border-collapse:collapse;font-size:13px;margin-bottom:20px">
                    <thead><tr>
                      <th style="padding:10px 12px;text-align:left;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#94a3b8;background:#fafbff;border-bottom:1px solid rgba(0,0,0,0.06)">@(ne?"व्यायाम":"Exercise")</th>
                      <th style="padding:10px 12px;text-align:left;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#94a3b8;background:#fafbff;border-bottom:1px solid rgba(0,0,0,0.06)">@Tr("sets")</th>
                      <th style="padding:10px 12px;text-align:left;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#94a3b8;background:#fafbff;border-bottom:1px solid rgba(0,0,0,0.06)">@Tr("reps")</th>
                      <th style="padding:10px 12px;text-align:left;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#94a3b8;background:#fafbff;border-bottom:1px solid rgba(0,0,0,0.06)">@Tr("rest")</th>
                    </tr></thead>
                    <tbody>
                        @foreach (var ex in Model.TodaysWorkout.Exercises)
                        {
                        <tr style="border-bottom:1px solid rgba(0,0,0,0.04)">
                            <td style="padding:12px 12px;font-weight:700;color:#0f172a"><strong>@ex.ExerciseName</strong></td>
                            <td style="padding:12px 12px;color:#374151">@ex.Sets</td>
                            <td style="padding:12px 12px;color:#22c55e;font-weight:700">@ex.Reps</td>
                            <td style="padding:12px 12px;color:#64748b">@ex.RestSeconds s</td>
                        </tr>
                        }
                    </tbody>
                </table>
                <div style="display:flex;gap:10px;flex-wrap:wrap">
                    <form method="post" action="/Dashboard/CompleteWorkout" style="display:inline">
                        <input type="hidden" name="workoutId" value="@Model.TodaysWorkout.Id" />
                        <input type="hidden" name="duration" value="@Model.TodaysWorkout.DurationMinutes" />
                        <button type="submit" class="btn btn-success">✅ @Tr("complete_workout")</button>
                    </form>
                    <a href="/Workout/Details/@Model.TodaysWorkout.Id" class="btn btn-ghost">📋 @(ne?"विवरण हेर्नुहोस्":"Full Details")</a>
                </div>
                }
                else
                {
                <div style="text-align:center;padding:40px 0">
                    <div style="font-size:48px;margin-bottom:12px">🌟</div>
                    <div style="font-size:18px;font-weight:700;margin-bottom:8px">@(ne?"आराम दिन":"Recovery Day")</div>
                    <div style="color:#64748b">@(ne?"आराम गर्नुहोस् र भोलिको लागि तयार हुनुहोस्।":"Rest, recover, and come back stronger tomorrow.")</div>
                    <a href="/Running" class="btn btn-outline" style="margin-top:16px">🏃 @(ne?"सजिलो दौड लग गर्नुहोस्":"Log an Easy Run")</a>
                </div>
                }
            </div>
        </div>

        <!-- Weekly Progress Ring -->
        <div class="card">
            <div class="card-header"><div class="card-title">📊 @Tr("weekly_progress")</div></div>
            <div class="card-body" style="display:flex;flex-direction:column;align-items:center;padding:28px">
                <div class="progress-ring-container">
                    <svg class="ring-svg" width="130" height="130">
                        <defs>
                            <linearGradient id="rg" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#4f46e5"/>
                                <stop offset="100%" stop-color="#10b981"/>
                            </linearGradient>
                        </defs>
                        <circle class="ring-track" cx="65" cy="65" r="52"/>
                        <circle class="ring-progress" cx="65" cy="65" r="52"
                                style="stroke-dasharray:326.7;stroke-dashoffset:@(326.7 - (pct/100.0*326.7))"/>
                    </svg>
                    <div class="ring-center">
                        <div class="ring-pct">@pct%</div>
                        <div class="ring-sub">@(ne?"लक्ष्य":"of goal")</div>
                    </div>
                </div>
                <div style="margin-top:16px;text-align:center">
                    <div style="font-size:22px;font-weight:800">@Model.WeeklyCompleted / @Model.WorkoutDaysTarget</div>
                    <div style="color:var(--text-muted);font-size:13px">@(ne?"यस हप्ता व्यायाम":"workouts this week")</div>
                </div>
                <div class="prog-bar-track" style="width:100%;margin-top:14px">
                    <div class="prog-bar-fill pbf-green" data-pct="@pct" style="width:0%"></div>
                </div>
            </div>
        </div>

        <!-- BMI Card -->
        <div class="card">
            <div class="card-header"><div class="card-title">⚖️ @(ne?"BMI अवस्था":"BMI Status")</div><a href="/Bmi" class="btn btn-outline btn-sm">@(ne?"जाँच्नुहोस्":"Check")</a></div>
            <div class="card-body" style="text-align:center">
                @{
                    double heightM = user.HeightCm / 100.0;
                    double bmi = heightM > 0 ? Math.Round(user.WeightKg / (heightM * heightM), 1) : 0;
                    string bmiCat = bmi < 18.5 ? (ne?"कम तौल":"Underweight") : bmi < 25 ? (ne?"सामान्य":"Normal") : bmi < 30 ? (ne?"अधिक तौल":"Overweight") : (ne?"मोटोपन":"Obese");
                    string bmiClr = bmi < 18.5 ? "#3b82f6" : bmi < 25 ? "#059669" : bmi < 30 ? "#d97706" : "#dc2626";
                }
                <div style="font-size:44px;font-weight:900;color:@bmiClr;line-height:1">@bmi</div>
                <div style="font-weight:700;color:@bmiClr;margin:4px 0">@bmiCat</div>
                <div style="font-size:12px;color:var(--text-muted)">@user.HeightCm cm · @user.WeightKg kg</div>
                <a href="/Bmi" class="btn btn-ghost btn-sm" style="margin-top:14px;width:100%;justify-content:center">@(ne?"विस्तृत सुझाव पाउनुहोस्":"Get Detailed Suggestions →")</a>
            </div>
        </div>

        <!-- Recent Runs -->
        <div class="card span2">
            <div class="card-header">
                <div class="card-title">🏃 @(ne?"हालका दौडहरू":"Recent Runs")</div>
                <a href="/Running" class="btn btn-ghost btn-sm">@(ne?"सबै हेर्नुहोस्":"View All")</a>
            </div>
            <div class="card-body">
                @if (Model.RecentRuns.Any())
                {
                    @foreach (var run in Model.RecentRuns.Take(3))
                    {
                    <div class="run-item">
                        <div class="run-dot">🏃</div>
                        <div class="run-main">
                            <div class="run-dist">@run.DistanceKm km</div>
                            <div class="run-meta">@run.RunType · @run.Date.ToString("MMM dd") · @run.DurationMinutes @(ne?"मिनेट":"min")</div>
                        </div>
                        <div>
                            <div class="run-pace-val">@run.PaceMinPerKm.ToString("0.0")</div>
                            <div class="run-pace-lbl">min/km</div>
                        </div>
                    </div>
                    }
                }
                else
                {
                <div style="text-align:center;padding:30px;color:#94a3b8">
                    🏃 @(ne?"कुनै दौड लग छैन।":"No runs logged yet.") <a href="/Running">@(ne?"पहिलो दौड लग गर्नुहोस् →":"Log your first run →")</a>
                </div>
                }
            </div>
        </div>

        <!-- Weight Progress -->
        <div class="card">
            <div class="card-header"><div class="card-title">⚖️ @(ne?"तौल प्रगति":"Weight Progress")</div><a href="/Progress" class="btn btn-ghost btn-sm">@(ne?"ट्र्याक":"Track")</a></div>
            <div class="card-body" style="text-align:center">
                @if (Model.LatestProgress?.WeightKg != null)
                {
                    var diff = (Model.LatestProgress.WeightKg ?? user.WeightKg) - user.WeightKg;
                    var sign = diff >= 0 ? "+" : "";
                <div style="font-size:38px;font-weight:900;color:#16a34a">@Model.LatestProgress.WeightKg kg</div>
                <div style="color:#94a3b8;font-size:12px;margin-top:4px">@Model.LatestProgress.Date.ToString("MMM dd")</div>
                <div style="margin-top:12px;background:#f8faf8;border-radius:8px;padding:10px;font-size:13px;color:#374151">
                    @(ne?"शुरुवातदेखि:":"Change from start:")
                    <span style="font-weight:700;color:@(diff < 0 ? "#22c55e" : "#ef4444")">@sign@diff.ToString("0.1") kg</span>
                </div>
                }
                else
                {
                <div style="padding:24px;color:#94a3b8">
                    <div style="font-size:32px;margin-bottom:8px">⚖️</div>
                    <a href="/Progress">@(ne?"तौल लग गर्नुहोस् →":"Log weight →")</a>
                </div>
                }
            </div>
        </div>

        <!-- Goals + Quick Actions -->
        <div class="card">
            <div class="card-header"><div class="card-title">🎯 @(ne?"मेरो लक्ष्यहरू":"My Goals")</div><a href="/Settings" class="btn btn-ghost btn-sm">@(ne?"सम्पादन":"Edit")</a></div>
            <div class="card-body">
                <div style="display:flex;flex-wrap:wrap;gap:7px;margin-bottom:16px">
                    @if (user.Goals.Any()) {
                        @foreach (var g in user.Goals) { <span class="badge badge-indigo">@g</span> }
                    } else { <a href="/Settings" class="btn btn-ghost btn-sm">@(ne?"लक्ष्य थप्नुहोस्":"Add goals →")</a> }
                </div>
                <hr class="divider" />
                <div style="display:flex;flex-direction:column;gap:8px">
                    <a href="/Running" class="btn btn-ghost btn-sm" style="justify-content:flex-start">🏃 @Tr("log_run")</a>
                    <a href="/Progress" class="btn btn-ghost btn-sm" style="justify-content:flex-start">📊 @Tr("track_progress")</a>
                    <a href="/Bmi" class="btn btn-ghost btn-sm" style="justify-content:flex-start">⚖️ @(ne?"BMI जाँच्नुहोस्":"Check BMI")</a>
                    <a href="/Health" class="btn btn-ghost btn-sm" style="justify-content:flex-start">🏥 @(ne?"स्वास्थ्य जानकारी":"Health Info")</a>
                </div>
            </div>
        </div>

        <!-- ── Activity Widget ── -->
        @{
            var actStats = ViewBag.ActivityStats as FitForgeAI.Services.ActivityStats;
            var recentActs = ViewBag.RecentActivities as List<FitForgeAI.Models.Activity> ?? new();
            var actSuggestions = ViewBag.ActivitySuggestions as List<string> ?? new();
            string AIcon(string t) => t.ToLower() switch { "run"=>"🏃","ride"or"cycling"=>"🚴","walk"=>"🚶","swim"=>"🏊","gym"=>"🏋️","hiit"=>"⚡","yoga"=>"🧘","hike"=>"🥾",_=>"💪" };
            string AColor(string t) => t.ToLower() switch { "run"=>"#f87171","ride"or"cycling"=>"#60a5fa","walk"=>"#4ade80","swim"=>"#38bdf8","gym"=>"#a78bfa","hiit"=>"#fb923c","yoga"=>"#f472b6","hike"=>"#86efac",_=>"#f5c542" };
        }
        <div class="card span3" style="background:#ffffff;border:1px solid rgba(0,0,0,0.08)">
            <div class="card-header" style="display:flex;align-items:center;justify-content:space-between">
                <div class="card-title">🏅 @(ne?"यो हप्ताको गतिविधि":"This Week's Activity")</div>
                <a href="/Activity/Log" style="font-size:12px;font-weight:700;color:var(--accent,#f5c542);padding:6px 14px;border:1px solid rgba(245,197,66,0.3);border-radius:8px">+ @(ne?"थप्नुहोस्":"Log")</a>
            </div>
            <div class="card-body">
                <!-- Mini stats row -->
                <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px">
                    @foreach (var s in new[]{
                        ("🏃", actStats?.TotalSessions.ToString() ?? "0", ne?"सत्र":"Sessions"),
                        ("⏱️", (actStats?.TotalMinutes ?? 0) + "m", ne?"मिनेट":"Minutes"),
                        ("📍", (actStats?.TotalKm ?? 0).ToString("0.0") + "km", ne?"दूरी":"Distance"),
                        ("🔥", (actStats?.TotalCalories ?? 0).ToString(), ne?"क्यालोरी":"Calories")
                    })
                    {
                    <div style="background:#f9f9f8;border-radius:10px;padding:10px;text-align:center">
                        <div style="font-size:16px;margin-bottom:3px">@s.Item1</div>
                        <div style="font-size:16px;font-weight:900;color:#18181b;letter-spacing:-0.02em">@s.Item2</div>
                        <div style="font-size:10px;color:#a1a1aa;font-weight:600">@s.Item3</div>
                    </div>
                    }
                </div>

                <!-- Recent activities -->
                @if (recentActs.Any())
                {
                @foreach (var a in recentActs)
                {
                var ic = AIcon(a.Type); var cl = AColor(a.Type);
                <div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(0,0,0,0.07)">
                    <div style="width:34px;height:34px;background:@(cl)18;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0">@ic</div>
                    <div style="flex:1;min-width:0">
                        <div style="font-size:13px;font-weight:700;color:#18181b">@(!string.IsNullOrEmpty(a.Title)?a.Title:$"{a.Type} Session")</div>
                        <div style="font-size:11px;color:#71717a">@a.Date.ToString("MMM dd") · @a.DurationMinutes min@(a.DistanceKm.HasValue ? $" · {a.DistanceKm:0.0}km" : "")</div>
                    </div>
                    <div style="font-size:12px;font-weight:700;color:#71717a">🔥 @a.CaloriesBurned cal</div>
                </div>
                }
                <a href="/Activity" style="display:block;text-align:center;padding:10px;color:#71717a;font-size:12px;font-weight:700;margin-top:8px">@(ne?"सबै हेर्नुहोस्":"View all activities →")</a>
                }
                else
                {
                <div style="text-align:center;padding:20px;color:#a1a1aa">
                    <div style="font-size:32px;margin-bottom:8px">🏅</div>
                    <div style="font-size:13px;font-weight:600;margin-bottom:12px">@(ne?"अझै कुनै गतिविधि छैन":"No activities this week")</div>
                    <a href="/Activity/Log" style="padding:9px 20px;background:var(--accent,#22c55e);color:#ffffff;font-weight:800;border-radius:10px;font-size:13px">+ @(ne?"पहिलो गतिविधि लग गर्नुहोस्":"Log Your First Activity")</a>
                </div>
                }

                <!-- Top suggestion -->
                @if (actSuggestions.Any())
                {
                <div style="background:#f0fdf4;border:1px solid rgba(34,197,94,0.2);border-radius:10px;padding:10px 14px;margin-top:12px;font-size:12px;color:#374151">
                    🤖 @actSuggestions.First()
                </div>
                }
            </div>
        </div>

        <!-- Quote -->
        <div class="card span3" style="background:linear-gradient(135deg,var(--indigo-bg),var(--green-bg))">
            <div class="card-body" style="display:flex;align-items:center;gap:18px;padding:24px">
                <div style="font-size:40px">💡</div>
                <div>
                    <div style="font-size:16px;font-weight:700;font-style:italic">"@Model.MotivationalQuote"</div>
                    <div style="font-size:12px;color:var(--indigo);font-weight:600;margin-top:5px">— @(ne?"दैनिक प्रेरणा":"Daily Motivation")</div>
                </div>
            </div>
        </div>

    </div>
</div>
