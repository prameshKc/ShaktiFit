@model FitForgeAI.ViewModels.LoginViewModel
@{ ViewBag.Title = "Login – ShaktiFit"; ViewBag.IsLanding = true; }
@{ var lang = Context.Session.GetString("Lang") ?? "en"; bool ne = lang == "ne"; }

<div class="auth-page">
    <div class="auth-left">
        <div class="auth-box">
            <div class="auth-logo-wrap">
                <div class="logo-icon-box">💪</div>
                <div>
                    <div style="font-size:18px;font-weight:800">ShaktiFit</div>
                    <div style="font-size:11px;color:var(--text-muted)">स्वास्थ्य फिट</div>
                </div>
            </div>
            <h1 class="auth-title">@(ne?"स्वागत छ! फेरि आउनुभयो":"Welcome back, Athlete")</h1>
            <p class="auth-sub">@(ne?"आफ्नो यात्रा जारी राख्नुहोस्।":"Continue your fitness journey.")</p>

            @if (!ViewData.ModelState.IsValid)
            {
            <div class="alert alert-danger">@(ne?"इमेल वा पासवर्ड गलत छ।":"Invalid email or password.")</div>
            }

            <form method="post" action="/Account/Login">
                <div class="form-group">
                    <label class="form-label">@(ne?"इमेल ठेगाना":"Email Address")</label>
                    <input type="email" name="Email" class="form-control" placeholder="you@example.com" required />
                </div>
                <div class="form-group">
                    <label class="form-label">@(ne?"पासवर्ड":"Password")</label>
                    <input type="password" name="Password" class="form-control" placeholder="••••••••" required />
                </div>
                <button type="submit" class="btn btn-primary btn-block" style="margin-top:4px;padding:13px">
                    💪 @(ne?"लगइन गर्नुहोस्":"Login to ShaktiFit")
                </button>
            </form>

            <!-- Divider -->
            <div style="display:flex;align-items:center;gap:12px;margin:20px 0">
              <div style="flex:1;height:1px;background:rgba(0,0,0,.08)"></div>
              <span style="font-size:12px;font-weight:600;color:#94a3b8">OR</span>
              <div style="flex:1;height:1px;background:rgba(0,0,0,.08)"></div>
            </div>

            <!-- Google Sign-In -->
            <a href="/Account/GoogleLogin"
               style="display:flex;align-items:center;justify-content:center;gap:12px;width:100%;padding:13px;background:#fff;border:1.5px solid rgba(0,0,0,.12);border-radius:12px;font-size:14px;font-weight:700;color:#374151;text-decoration:none;transition:all .15s;box-shadow:0 1px 3px rgba(0,0,0,.06)"
               onmouseover="this.style.background='#f8faf8';this.style.borderColor='rgba(34,197,94,.4)'"
               onmouseout="this.style.background='#fff';this.style.borderColor='rgba(0,0,0,.12)'">
              <svg width="20" height="20" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              @(ne?"Google बाट लगइन गर्नुहोस्":"Continue with Google")
            </a>

            <div style="text-align:center;margin-top:20px;font-size:14px;color:var(--text-secondary)">
                @(ne?"नयाँ सदस्य?":"New here?")
                <a href="/Account/Register" style="color:var(--indigo);font-weight:600">@(ne?"दर्ता गर्नुहोस् →":"Create account →")</a>
            </div>

            <hr class="divider" />
            <div style="text-align:center;font-size:13px;color:var(--text-muted)">@(ne?"खाता बिना पनि":"No account? Still explore")</div>
            <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">
                <a href="/Bmi" class="btn btn-ghost btn-sm" style="flex:1;justify-content:center">⚖️ BMI @(ne?"जाँच":"Check")</a>
                <a href="/Exercise" class="btn btn-ghost btn-sm" style="flex:1;justify-content:center">🏋️ @(ne?"व्यायाम":"Exercises")</a>
                <a href="/Health" class="btn btn-ghost btn-sm" style="flex:1;justify-content:center">🏥 @(ne?"स्वास्थ्य":"Health")</a>
            </div>
        </div>
    </div>
    <div class="auth-right">
        <div style="text-align:center;max-width:360px">
            <div style="font-size:72px;margin-bottom:20px">💪</div>
            <h2 style="font-size:26px;margin-bottom:12px">@(ne?"तपाईंको शक्ति।":"Your Goals.") <br/><span class="text-gradient">@(ne?"तपाईंको लक्ष्य।":"Your Progress.")</span><br/>@(ne?"तपाईंको नतिजा।":"Your Results.")</h2>
            <p style="color:var(--text-secondary);font-size:14px;margin-top:12px">@(ne?"लगइन गरेर आफ्नो व्यक्तिगत योजना, BMI ट्र्याकिङ र प्रगति हेर्नुहोस्।":"Login to access your personalized plan, BMI tracking, and progress history.")</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:24px">
                @foreach (var f in new[]{("📊","Dashboard"),("⚖️","BMI Track"),("🏋️","Workouts"),("📈","Progress")})
                {
                <div style="background:white;border:1px solid var(--border);border-radius:10px;padding:14px;text-align:center">
                    <div style="font-size:24px;margin-bottom:4px">@f.Item1</div>
                    <div style="font-size:12px;font-weight:600;color:var(--text-secondary)">@f.Item2</div>
                </div>
                }
            </div>
        </div>
    </div>
</div>
