@{
    ViewBag.Title = "Calorie Calculator – ShaktiFit";
    var isAuth = Context.Session.GetString("UserId") != null;
    if (!isAuth) { ViewBag.IsLanding = true; }
    ViewBag.ActiveNav = "calorie";
    var lang = Context.Session.GetString("Lang") ?? "en";
    bool ne = lang == "ne";

    int? bmr    = ViewBag.Bmr    as int?;
    int? tdee   = ViewBag.Tdee   as int?;
    int? target = ViewBag.Target as int?;
    int? prot   = ViewBag.ProteinG as int?;
    int? fat    = ViewBag.FatG   as int?;
    int? carb   = ViewBag.CarbG  as int?;

    double age    = ViewBag.Age    is double a  ? a  : 0;
    double height = ViewBag.Height is double h  ? h  : 0;
    double weight = ViewBag.Weight is double w  ? w  : 0;
    string gender   = ViewBag.Gender   as string ?? "male";
    string activity = ViewBag.Activity as string ?? "moderate";
    string goal     = ViewBag.Goal     as string ?? "maintain";

    bool hasResult = bmr.HasValue;

    string goalLabel = goal switch {
        "lose_fast" => ne ? "छिटो तौल घटाउने"  : "Lose fast",
        "lose"      => ne ? "तौल घटाउने"        : "Lose weight",
        "maintain"  => ne ? "तौल कायम राख्ने"   : "Maintain",
        "gain"      => ne ? "मांसपेशी बनाउने"   : "Build muscle",
        "gain_fast" => ne ? "छिटो बल्क"         : "Bulk up",
        _ => "Maintain"
    };
    string goalColor = goal switch {
        "lose_fast" or "lose" => "#ef4444",
        "maintain"            => "#22c55e",
        "gain" or "gain_fast" => "#3b82f6",
        _ => "#22c55e"
    };

    int protCal  = prot.HasValue ? prot.Value * 4 : 0;
    int carbCal  = carb.HasValue ? carb.Value * 4 : 0;
    int fatCal   = fat.HasValue  ? fat.Value  * 9 : 0;
    int totalCal = protCal + carbCal + fatCal;
    int protPct  = totalCal > 0 ? (int)Math.Round((double)protCal / totalCal * 100) : 0;
    int carbPct  = totalCal > 0 ? (int)Math.Round((double)carbCal / totalCal * 100) : 0;
    int fatPct   = totalCal > 0 ? (int)Math.Round((double)fatCal  / totalCal * 100) : 0;

    // Meal split
    int mealB = hasResult ? (int)Math.Round(target!.Value * 0.25) : 0;
    int mealL = hasResult ? (int)Math.Round(target!.Value * 0.35) : 0;
    int mealD = hasResult ? (int)Math.Round(target!.Value * 0.30) : 0;
    int mealS = hasResult ? target!.Value - mealB - mealL - mealD : 0;

    var tips = goal switch {
        "lose_fast" or "lose" => ne
          ? new[]{"प्रोटिन धेरै खानुहोस् — यसले भोक कम गर्छ","मीठो पेय बन्द गर्नुहोस्","सब्जी र फलफूल भरपूर खानुहोस्","पर्याप्त पानी पिउनुहोस् (३+ लिटर)","खाना बिस्तारै चपाउनुहोस्"}
          : new[]{"High protein keeps you full and preserves muscle","Eliminate liquid calories (soda, juice, alcohol)","Fill half your plate with vegetables","Drink 3+ liters of water daily","Eat slowly — it takes 20 min to feel full"},
        "gain" or "gain_fast" => ne
          ? new[]{"खाना नछोड्नुहोस् — नियमित खानुहोस्","नट्स, एभोकाडो जस्ता क्यालोरी-घना खाना खानुहोस्","व्यायामपछि प्रोटिन + कार्ब खानुहोस्","राम्रो सुत्नुहोस् — मांसपेशी सुतेको बेला बन्छ","हप्तामा ३-४ पटक शक्ति व्यायाम गर्नुहोस्"}
          : new[]{"Never skip meals — eat consistently throughout the day","Include calorie-dense foods: nuts, avocado, olive oil","Post-workout: 30-40g protein + carbs within 45 min","Sleep 8 hours — muscles grow during recovery","Strength train 3-4x per week"},
        _ => ne
          ? new[]{"सन्तुलित म्याक्रो खानुहोस्","नियमित व्यायाम जारी राख्नुहोस्","प्रशोधित खाना कम गर्नुहोस्","पर्याप्त पानी पिउनुहोस्","तनाव कम गर्नुहोस्"}
          : new[]{"Keep macros balanced — don't cut any food group","Stay consistent with exercise","Minimize processed foods","Stay hydrated — 2.5-3L water daily","Manage stress — cortisol raises appetite"}
    };

    // Build select HTML to avoid Razor tag-helper conflict
    var actOpts = new[]{
        ("sedentary",  "🪑", ne?"बस्ने काम (व्यायाम छैन)":"Sedentary (no exercise)"),
        ("light",      "🚶", ne?"हल्का (हप्तामा १-३ दिन)":"Lightly active (1-3 days/week)"),
        ("moderate",   "🏃", ne?"मध्यम (हप्तामा ३-५ दिन)":"Moderately active (3-5 days/week)"),
        ("active",     "💪", ne?"सक्रिय (हप्तामा ६-७ दिन)":"Very active (6-7 days/week)"),
        ("very_active","🔥", ne?"अत्यन्त सक्रिय (दिनमा दुई पटक)":"Extra active (2x/day)"),
    };
    var goalOpts = new[]{
        ("lose_fast","📉", ne?"छिटो तौल घटाउने (-750 cal)":"Lose fast (-750 cal/day)"),
        ("lose",     "⬇️", ne?"तौल घटाउने (-500 cal)":"Lose weight (-500 cal/day)"),
        ("maintain", "⚖️", ne?"तौल कायम राख्ने":"Maintain weight"),
        ("gain",     "⬆️", ne?"मांसपेशी बनाउने (+400 cal)":"Build muscle (+400 cal/day)"),
        ("gain_fast","📈", ne?"छिटो बल्क (+700 cal)":"Bulk up fast (+700 cal/day)"),
    };
    var actSb  = new System.Text.StringBuilder("<select class=\"bp-sel\" name=\"activity\">");
    foreach (var o in actOpts)
        actSb.Append($"<option value=\"{o.Item1}\"{(activity==o.Item1?" selected":"")}>{o.Item2} {o.Item3}</option>");
    actSb.Append("</select>");
    var goalSb = new System.Text.StringBuilder("<select class=\"bp-sel\" name=\"goal\">");
    foreach (var o in goalOpts)
        goalSb.Append($"<option value=\"{o.Item1}\"{(goal==o.Item1?" selected":"")}>{o.Item2} {o.Item3}</option>");
    goalSb.Append("</select>");
}

<style>
  /* ── mirrors BMI page design ── */
  .bp { background:#f8faf8; min-height:100vh; padding:20px 16px 40px; }
  .bp-inner { max-width:880px; margin:0 auto; }
  .bp-title { font-size:24px; font-weight:900; color:#0f172a; letter-spacing:-0.02em; margin-bottom:4px; }
  .bp-sub { font-size:13px; color:#64748b; margin-bottom:24px; }
  .bp-tag { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:var(--accent,#22c55e); margin-bottom:6px; }

  /* form card */
  .bp-form { background:#ffffff; border:1px solid rgba(0,0,0,0.08); border-radius:18px; padding:20px; margin-bottom:20px; }
  .bp-form-title { font-size:15px; font-weight:800; color:#18181b; margin-bottom:18px; padding-bottom:12px; border-bottom:1px solid rgba(0,0,0,0.07); }
  .bp-lbl { font-size:12px; font-weight:700; color:#71717a; margin-bottom:6px; letter-spacing:0.03em; }
  .bp-inp { width:100%; background:#f9f9f8; border:1.5px solid rgba(0,0,0,0.1); border-radius:12px; color:#18181b; padding:13px 16px; font-size:18px; font-family:inherit; outline:none; margin-bottom:14px; transition:border-color .15s; -webkit-appearance:none; box-sizing:border-box; }
  .bp-inp:focus { border-color:var(--accent,#22c55e); }
  .bp-inp::placeholder { color:#a1a1aa; font-size:15px; }
  .bp-sel { width:100%; background:#f9f9f8; border:1.5px solid rgba(0,0,0,0.1); border-radius:12px; color:#18181b; padding:12px 14px; font-size:14px; font-family:inherit; outline:none; margin-bottom:14px; cursor:pointer; box-sizing:border-box; }
  .bp-btn { width:100%; padding:15px; background:var(--accent,#22c55e); color:#ffffff; font-weight:800; font-size:15px; border:none; border-radius:12px; cursor:pointer; font-family:inherit; letter-spacing:0.01em; }

  /* gender toggle */
  .bp-gender { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:14px; }
  .bp-gender-btn { padding:12px; border:1.5px solid rgba(0,0,0,0.1); border-radius:12px; background:#f9f9f8; font-size:13px; font-weight:700; color:#71717a; cursor:pointer; transition:all .15s; font-family:inherit; }
  .bp-gender-btn.active { border-color:var(--accent,#22c55e); background:rgba(34,197,94,0.07); color:#16a34a; }

  /* result card */
  .bp-result { background:#ffffff; border-radius:18px; padding:24px 20px; text-align:center; margin-bottom:16px; border-width:1.5px; border-style:solid; }
  .bp-result-label { font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px; }
  .bp-result-num { font-size:64px; font-weight:900; letter-spacing:-0.04em; line-height:1; margin-bottom:4px; }
  .bp-result-sub { font-size:12px; color:#a1a1aa; margin-bottom:18px; }
  .bp-stats { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; }
  .bp-stat { background:#f9f9f8; border-radius:12px; padding:14px; text-align:center; }
  .bp-stat-val { font-size:20px; font-weight:800; color:#18181b; }
  .bp-stat-lbl { font-size:10px; color:#a1a1aa; margin-top:2px; text-transform:uppercase; letter-spacing:0.06em; }

  /* info cards */
  .bp-card { background:#ffffff; border:1px solid rgba(0,0,0,0.08); border-radius:18px; margin-bottom:16px; overflow:hidden; }
  .bp-card-head { padding:14px 18px; border-bottom:1px solid rgba(0,0,0,0.07); font-size:14px; font-weight:800; color:#18181b; }
  .bp-card-body { padding:4px 18px 16px; }
  .bp-item { display:flex; align-items:flex-start; gap:10px; padding:10px 0; border-bottom:1px solid rgba(0,0,0,0.06); font-size:13px; color:#52525b; line-height:1.5; }
  .bp-item:last-child { border-bottom:none; }
  .bp-item-dot { width:6px; height:6px; border-radius:50%; background:var(--accent,#22c55e); margin-top:5px; flex-shrink:0; }

  /* macro bar */
  .macro-bar { height:10px; border-radius:999px; display:flex; overflow:hidden; margin:10px 0 8px; }
  .macro-row { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-top:14px; }
  .macro-box { border-radius:12px; padding:14px; text-align:center; }

  /* meal row */
  .meal-row { display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid rgba(0,0,0,0.06); font-size:13px; color:#52525b; }
  .meal-row:last-child { border-bottom:none; }

  /* empty state */
  .bp-empty { background:#f9f9f8; border:1px solid rgba(0,0,0,0.07); border-radius:18px; padding:60px 20px; text-align:center; }

  /* two-col layout */
  @@media (min-width:680px) {
    .bp { padding:28px 24px 60px; }
    .bp-layout { display:grid; grid-template-columns:320px 1fr; gap:20px; align-items:start; }
    .bp-form { position:sticky; top:80px; margin-bottom:0; }
  }
</style>

<div class="bp">
<div class="bp-inner">

  <div class="bp-tag">🔥 @(ne?"पोषण उपकरण":"Nutrition Tool")</div>
  <div class="bp-title">@(ne?"क्यालोरी क्याल्कुलेटर":"Calorie Calculator")</div>
  <div class="bp-sub">@(ne?"Mifflin-St Jeor सूत्रले तपाईंको दैनिक TDEE, BMR र म्याक्रो लक्ष्य गणना गर्नुहोस्।":"Calculate your daily TDEE, BMR, and macro targets using the Mifflin-St Jeor formula.")</div>

  <div class="bp-layout">

    <!-- FORM -->
    <div class="bp-form">
      <div class="bp-form-title">📋 @(ne?"तपाईंको जानकारी":"Your Details")</div>
      <form method="post" action="/Calorie/Calculate">
        @Html.AntiForgeryToken()
        <input type="hidden" name="gender" id="genderInput" value="@gender" />

        <div class="bp-lbl">@(ne?"लिंग":"Gender")</div>
        <div class="bp-gender">
          <button type="button" class="bp-gender-btn @(gender=="male"?"active":"")" onclick="setGender('male',this)">♂ @(ne?"पुरुष":"Male")</button>
          <button type="button" class="bp-gender-btn @(gender=="female"?"active":"")" onclick="setGender('female',this)">♀ @(ne?"महिला":"Female")</button>
        </div>

        <div class="bp-lbl">@(ne?"उमेर (वर्ष)":"Age (years)")</div>
        <input class="bp-inp" type="number" name="age" min="10" max="100" placeholder="e.g. 25"
               value="@(age > 0 ? age.ToString() : "")" inputmode="numeric" required />

        <div class="bp-lbl">@(ne?"उचाइ (cm)":"Height (cm)")</div>
        <input class="bp-inp" type="number" name="height" min="100" max="250" placeholder="e.g. 170"
               value="@(height > 0 ? height.ToString() : "")" inputmode="decimal" required />

        <div class="bp-lbl">@(ne?"तौल (kg)":"Weight (kg)")</div>
        <input class="bp-inp" type="number" name="weight" min="30" max="300" step="0.1" placeholder="e.g. 70"
               value="@(weight > 0 ? weight.ToString() : "")" inputmode="decimal" required />

        <div class="bp-lbl">@(ne?"गतिविधि स्तर":"Activity Level")</div>
        @Html.Raw(actSb.ToString())

        <div class="bp-lbl">@(ne?"लक्ष्य":"Your Goal")</div>
        @Html.Raw(goalSb.ToString())

        <button class="bp-btn" type="submit">🔥 @(ne?"क्यालोरी गणना गर्नुहोस्":"Calculate My Calories")</button>
      </form>
    </div>

    <!-- RESULTS -->
    <div>
      @if (hasResult)
      {
      <!-- Big number -->
      <div class="bp-result" style="border-color:@goalColor">
        <div class="bp-result-label" style="color:@goalColor">@goalLabel</div>
        <div class="bp-result-num" style="color:@goalColor">@target</div>
        <div class="bp-result-sub">@(ne?"क्यालोरी / दिन":"calories per day")</div>
        <div class="bp-stats">
          <div class="bp-stat">
            <div class="bp-stat-val">@bmr</div>
            <div class="bp-stat-lbl">BMR</div>
          </div>
          <div class="bp-stat">
            <div class="bp-stat-val">@tdee</div>
            <div class="bp-stat-lbl">TDEE</div>
          </div>
          <div class="bp-stat" style="background:rgba(34,197,94,0.07)">
            <div class="bp-stat-val" style="color:@goalColor">@target</div>
            <div class="bp-stat-lbl">@(ne?"लक्ष्य":"Target")</div>
          </div>
        </div>
        <div style="font-size:11px;color:#a1a1aa;margin-top:10px">
          BMR = @(ne?"आराम क्यालोरी":"calories at rest") · TDEE = @(ne?"कुल दैनिक खर्च":"total daily burn")
        </div>
      </div>

      <!-- Macros -->
      <div class="bp-card">
        <div class="bp-card-head">💊 @(ne?"म्याक्रोन्युट्रिएन्ट":"Macronutrients")</div>
        <div class="bp-card-body">
          <div class="macro-bar">
            <div style="width:@protPct%;background:#3b82f6"></div>
            <div style="width:@carbPct%;background:#f59e0b"></div>
            <div style="width:@fatPct%;background:#ef4444"></div>
          </div>
          <div style="display:flex;gap:14px;flex-wrap:wrap;font-size:12px;color:#71717a;margin-bottom:4px">
            <span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#3b82f6;margin-right:4px"></span>@(ne?"प्रोटिन":"Protein") @protPct%</span>
            <span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#f59e0b;margin-right:4px"></span>@(ne?"कार्ब":"Carbs") @carbPct%</span>
            <span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#ef4444;margin-right:4px"></span>@(ne?"फ्याट":"Fat") @fatPct%</span>
          </div>
          <div class="macro-row">
            <div class="macro-box" style="background:#eff6ff;text-align:center">
              <div style="font-size:22px;font-weight:900;color:#3b82f6">@prot<span style="font-size:12px">g</span></div>
              <div style="font-size:10px;font-weight:700;color:#a1a1aa;text-transform:uppercase;margin-top:2px">@(ne?"प्रोटिन":"Protein")</div>
              <div style="font-size:11px;color:#3b82f6;margin-top:2px">@protCal cal</div>
            </div>
            <div class="macro-box" style="background:#fffbeb;text-align:center">
              <div style="font-size:22px;font-weight:900;color:#f59e0b">@carb<span style="font-size:12px">g</span></div>
              <div style="font-size:10px;font-weight:700;color:#a1a1aa;text-transform:uppercase;margin-top:2px">@(ne?"कार्ब":"Carbs")</div>
              <div style="font-size:11px;color:#f59e0b;margin-top:2px">@carbCal cal</div>
            </div>
            <div class="macro-box" style="background:#fef2f2;text-align:center">
              <div style="font-size:22px;font-weight:900;color:#ef4444">@fat<span style="font-size:12px">g</span></div>
              <div style="font-size:10px;font-weight:700;color:#a1a1aa;text-transform:uppercase;margin-top:2px">@(ne?"फ्याट":"Fat")</div>
              <div style="font-size:11px;color:#ef4444;margin-top:2px">@fatCal cal</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Meal split -->
      <div class="bp-card">
        <div class="bp-card-head">🍽️ @(ne?"खानाको बाँडफाँड":"Meal Distribution")</div>
        <div class="bp-card-body">
          @foreach (var row in new[]{
            ("🌅", ne?"बिहानको खाना":"Breakfast", mealB),
            ("☀️", ne?"दिउँसोको खाना":"Lunch",     mealL),
            ("🌙", ne?"बेलुकाको खाना":"Dinner",    mealD),
            ("🍎", ne?"खाजा":"Snacks",              mealS)
          }) {
          <div class="meal-row">
            <div style="display:flex;align-items:center;gap:8px">
              <span style="font-size:18px">@row.Item1</span>
              <strong>@row.Item2</strong>
            </div>
            <div style="font-weight:800;color:#18181b">@row.Item3 <span style="font-size:11px;color:#a1a1aa;font-weight:400">cal</span></div>
          </div>
          }
        </div>
      </div>

      <!-- Tips -->
      <div class="bp-card">
        <div class="bp-card-head">💡 @(ne?"पोषण सुझावहरू":"Nutrition Tips")</div>
        <div class="bp-card-body">
          @foreach (var t in tips) {
          <div class="bp-item">
            <div class="bp-item-dot"></div>
            <div>@t</div>
          </div>
          }
        </div>
      </div>
      }
      else
      {
      <!-- Empty state -->
      <div class="bp-empty">
        <div style="font-size:52px;margin-bottom:16px">🔥</div>
        <div style="font-size:17px;font-weight:800;color:#18181b;margin-bottom:8px">@(ne?"आफ्नो क्यालोरी थाहा पाउनुहोस्":"Discover your calorie needs")</div>
        <div style="font-size:13px;color:#71717a;margin-bottom:28px">@(ne?"फारम भर्नुहोस् र तपाईंको TDEE, BMR र म्याक्रो लक्ष्य पत्ता लगाउनुहोस्":"Fill in the form to get your personalized TDEE, BMR, and macro targets")</div>
        @foreach (var item in new[]{
          ("🔥","BMR – calories your body burns at rest"),
          ("⚡","TDEE – your total daily calorie burn"),
          ("🎯","Target calories adjusted for your goal"),
          ("💊","Protein, carb & fat breakdown"),
          ("🍽️","Meal split across breakfast, lunch & dinner")
        }) {
        <div style="display:flex;align-items:center;gap:10px;font-size:13px;color:#52525b;padding:8px 0;border-bottom:1px solid rgba(0,0,0,0.06);max-width:320px;margin:0 auto">
          <span style="font-size:18px">@item.Item1</span><span>@item.Item2</span>
        </div>
        }
      </div>
      }
    </div>

  </div>
</div>
</div>

<script>
function setGender(val, btn) {
  document.getElementById('genderInput').value = val;
  document.querySelectorAll('.bp-gender-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}
</script>
