@model List<FitForgeAI.Models.Activity>
@{
    ViewBag.Title = "My Activities – ShaktiFit";
    var lang = Context.Session.GetString("Lang") ?? "en";
    bool ne = lang == "ne";
    var stats = (FitForgeAI.Services.ActivityStats)ViewBag.Stats;
    var suggestions = (List<string>)ViewBag.Suggestions;

    string TypeIcon(string t) => t.ToLower() switch {
        "run"  => "🏃", "ride" or "cycling" => "🚴", "walk" => "🚶",
        "swim" => "🏊", "gym"  => "🏋️",  "hiit" => "⚡",
        "yoga" => "🧘", "hike" => "🥾",  _ => "💪"
    };
    string TypeColor(string t) => t.ToLower() switch {
        "run"  => "#f87171", "ride" or "cycling" => "#60a5fa", "walk" => "#4ade80",
        "swim" => "#38bdf8", "gym"  => "#a78bfa", "hiit" => "#fb923c",
        "yoga" => "#f472b6", "hike" => "#86efac",  _ => "#f5c542"
    };
    string IntColor(string i) => i switch {
        "Easy" => "#22c55e", "Hard" => "#ef4444", _ => "#f59e0b"
    };
}

@if (TempData["Success"] != null)
{
<div id="toast" style="position:fixed;bottom:100px;left:50%;transform:translateX(-50%);background:#22c55e;color:#fff;padding:12px 24px;border-radius:12px;font-weight:700;font-size:14px;z-index:9999;box-shadow:0 4px 20px rgba(34,197,94,0.4)">
    ✅ @TempData["Success"]
</div>
<script>setTimeout(()=>document.getElementById('toast')?.remove(),3000)</script>
}

<style>
.act-page { background:var(--bg-primary,#fafaf9); min-height:100vh; padding:24px 20px 80px; }
.act-inner { max-width:900px; margin:0 auto; }

/* Header */
.act-header { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:24px; }
.act-title { font-size:24px; font-weight:900; color:#18181b; letter-spacing:-0.02em; }
.act-log-btn { display:inline-flex; align-items:center; gap:8px; padding:11px 20px; background:var(--accent,#f5c542); color:#1c1917; font-weight:800; font-size:14px; border-radius:12px; text-decoration:none; }

/* Weekly stats */
.stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:24px; }
.stat-card { background:#ffffff; border:1px solid rgba(0,0,0,0.08); border-radius:16px; padding:16px; text-align:center; }
.stat-val { font-size:28px; font-weight:900; color:#18181b; letter-spacing:-0.03em; line-height:1; margin-bottom:4px; }
.stat-lbl { font-size:11px; font-weight:600; color:#a1a1aa; text-transform:uppercase; letter-spacing:0.06em; }
.stat-icon { font-size:18px; margin-bottom:6px; }

/* Suggestions */
.suggest-card { background:#f0fdf4; border:1px solid rgba(34,197,94,0.2); border-radius:16px; padding:16px 20px; margin-bottom:24px; }
.suggest-title { font-size:13px; font-weight:800; color:var(--accent,#22c55e); margin-bottom:12px; display:flex; align-items:center; gap:6px; }
.suggest-item { display:flex; align-items:flex-start; gap:10px; padding:8px 0; border-bottom:1px solid rgba(0,0,0,0.06); font-size:13px; color:#52525b; line-height:1.5; }
.suggest-item:last-child { border-bottom:none; padding-bottom:0; }

/* Week chart */
.week-chart { background:#ffffff; border:1px solid rgba(0,0,0,0.08); border-radius:16px; padding:16px 20px; margin-bottom:24px; }
.chart-bars { display:flex; gap:6px; align-items:flex-end; height:60px; }
.chart-bar-wrap { flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; }
.chart-bar { width:100%; border-radius:6px 6px 0 0; background:#f3f4f6; min-height:4px; transition:height 0.3s; }
.chart-bar.has-data { background:var(--accent,#f59e0b); }
.chart-day { font-size:10px; color:#a1a1aa; font-weight:600; }
.chart-day.today { color:var(--accent,#f5c542); }

/* Activity list */
.act-list-title { font-size:13px; font-weight:800; color:#a1a1aa; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:12px; }
.act-card { background:#ffffff; border:1px solid rgba(0,0,0,0.08); border-radius:16px; padding:16px 18px; margin-bottom:10px; display:flex; align-items:center; gap:14px; position:relative; overflow:hidden; }
.act-card-stripe { position:absolute; left:0; top:0; bottom:0; width:3px; border-radius:3px 0 0 3px; }
.act-icon-box { width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:22px; flex-shrink:0; }
.act-info { flex:1; min-width:0; }
.act-name { font-size:15px; font-weight:800; color:#18181b; margin-bottom:2px; }
.act-meta { font-size:12px; color:#71717a; }
.act-stats { display:flex; gap:12px; flex-wrap:wrap; align-items:center; }
.act-stat { display:flex; flex-direction:column; align-items:flex-end; gap:2px; }
.act-stat-val { font-size:14px; font-weight:800; color:#18181b; }
.act-stat-lbl { font-size:10px; color:#a1a1aa; }
.act-int { font-size:10px; font-weight:700; padding:3px 8px; border-radius:999px; }
.act-delete { background:none; border:none; color:rgba(0,0,0,0.2); font-size:18px; cursor:pointer; padding:4px; transition:color 0.15s; flex-shrink:0; }
.act-delete:hover { color:#ef4444; }

/* Empty */
.act-empty { text-align:center; padding:60px 20px; color:#a1a1aa; }

/* Strava future banner */
.strava-banner { background:linear-gradient(135deg,rgba(252,76,2,0.15),rgba(252,76,2,0.05)); border:1px solid rgba(252,76,2,0.2); border-radius:16px; padding:16px 20px; margin-bottom:24px; display:flex; align-items:center; gap:14px; }

@@media (max-width:600px) {
  .stats-row { grid-template-columns:1fr 1fr; }
  .act-stats { display:none; }
  .act-card { gap:10px; }
}
</style>

<div class="act-page">
<div class="act-inner">

  <!-- Header -->
  <div class="act-header">
    <div>
      <div class="act-title">🏅 @(ne?"मेरो गतिविधिहरू":"My Activities")</div>
      <div style="font-size:13px;color:#71717a;margin-top:2px">@(ne?"यो हप्ताको सारांश":"This week's summary")</div>
    </div>
    <a href="/Activity/Log" class="act-log-btn">+ @(ne?"गतिविधि थप्नुहोस्":"Log Activity")</a>
  </div>

  <!-- Weekly Stats -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon">🏃</div>
      <div class="stat-val">@stats.TotalSessions</div>
      <div class="stat-lbl">@(ne?"सत्रहरू":"Sessions")</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">⏱️</div>
      <div class="stat-val">@stats.TotalMinutes<span style="font-size:14px;font-weight:600;color:#71717a">m</span></div>
      <div class="stat-lbl">@(ne?"मिनेट":"Minutes")</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">📍</div>
      <div class="stat-val">@stats.TotalKm.ToString("0.0")<span style="font-size:14px;font-weight:600;color:#71717a">km</span></div>
      <div class="stat-lbl">@(ne?"दूरी":"Distance")</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">🔥</div>
      <div class="stat-val">@stats.TotalCalories</div>
      <div class="stat-lbl">@(ne?"क्यालोरी":"Calories")</div>
    </div>
  </div>

  <!-- 7-day bar chart -->
  @{
    var today = DateTime.Now.Date;
    var days7 = Enumerable.Range(0, 7).Select(i => today.AddDays(-6 + i)).ToList();
    var byDay = Model.GroupBy(a => a.Date.Date).ToDictionary(g => g.Key, g => g.Sum(a => a.DurationMinutes));
    int maxMin = byDay.Any() ? byDay.Values.Max() : 1;
    string[] dayNames = { "Sun","Mon","Tue","Wed","Thu","Fri","Sat" };
    string[] dayNamesNe = { "आइत","सोम","मंगल","बुध","बिही","शुक्र","शनि" };
  }
  <div class="week-chart">
    <div style="font-size:12px;font-weight:800;color:#71717a;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:14px">📅 @(ne?"यो हप्ता":"This Week")</div>
    <div class="chart-bars">
      @foreach (var d in days7)
      {
      var mins = byDay.GetValueOrDefault(d, 0);
      var pct  = maxMin > 0 ? (int)((double)mins / maxMin * 100) : 0;
      var isToday = d == today;
      <div class="chart-bar-wrap">
        <div style="font-size:10px;color:#71717a;min-height:16px">@(mins > 0 ? $"{mins}m" : "")</div>
        <div class="chart-bar @(mins > 0 ? "has-data" : "")"
             style="height:@(Math.Max(pct * 48 / 100, mins > 0 ? 8 : 4))px;@(isToday && mins == 0 ? "border:1px dashed rgba(245,197,66,0.3);" : "")">
        </div>
        <div class="chart-day @(isToday ? "today" : "")">@(ne ? dayNamesNe[(int)d.DayOfWeek] : dayNames[(int)d.DayOfWeek])</div>
      </div>
      }
    </div>
  </div>

  <!-- Smart Suggestions -->
  @if (suggestions?.Any() == true)
  {
  <div class="suggest-card">
    <div class="suggest-title">🤖 @(ne?"स्मार्ट सुझावहरू":"Smart Suggestions")</div>
    @foreach (var s in suggestions)
    {
    <div class="suggest-item"><span>@s</span></div>
    }
  </div>
  }

  <!-- Future Strava banner -->
  <div class="strava-banner">
    <div style="font-size:28px">🟠</div>
    <div>
      <div style="font-size:13px;font-weight:800;color:rgba(252,76,2,0.9);margin-bottom:2px">Strava Integration Coming Soon</div>
      <div style="font-size:12px;color:#71717a">Once connected, your Strava runs & rides will sync automatically here.</div>
    </div>
  </div>

  <!-- Activity List -->
  <div class="act-list-title">@(ne?"सबै गतिविधिहरू":"All Activities") (@Model.Count)</div>

  @if (!Model.Any())
  {
  <div class="act-empty">
    <div style="font-size:56px;margin-bottom:14px">🏅</div>
    <div style="font-size:16px;font-weight:700;color:#71717a;margin-bottom:6px">@(ne?"अझै कुनै गतिविधि छैन":"No activities yet")</div>
    <div style="font-size:13px;margin-bottom:20px">@(ne?"तपाईंको पहिलो गतिविधि लग गर्नुहोस्!":"Log your first activity to get started!")</div>
    <a href="/Activity/Log" style="padding:12px 28px;background:var(--accent,#f5c542);color:#1c1917;font-weight:800;border-radius:12px;font-size:14px">+ @(ne?"गतिविधि थप्नुहोस्":"Log Activity")</a>
  </div>
  }
  else
  {
  @foreach (var a in Model)
  {
  var icon  = TypeIcon(a.Type);
  var color = TypeColor(a.Type);
  var icolor = IntColor(a.Intensity);
  <div class="act-card">
    <div class="act-card-stripe" style="background:@color"></div>
    <div class="act-icon-box" style="background:@(color)18">@icon</div>
    <div class="act-info">
      <div class="act-name">@(!string.IsNullOrEmpty(a.Title) ? a.Title : $"{a.Type} Session")</div>
      <div class="act-meta">
        @a.Date.ToString("MMM dd, yyyy") ·
        <span style="color:@icolor;font-weight:700">@a.Intensity</span>
        @if (a.HeartRateAvg.HasValue) { <text>· ❤️ @a.HeartRateAvg bpm</text> }
      </div>
      @if (!string.IsNullOrEmpty(a.Notes))
      {
      <div style="font-size:12px;color:#a1a1aa;margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:280px">@a.Notes</div>
      }
    </div>
    <div class="act-stats">
      <div class="act-stat">
        <div class="act-stat-val">@a.DurationMinutes<span style="font-size:10px;color:#71717a">m</span></div>
        <div class="act-stat-lbl">@(ne?"अवधि":"Duration")</div>
      </div>
      @if (a.DistanceKm.HasValue)
      {
      <div class="act-stat">
        <div class="act-stat-val">@a.DistanceKm.Value.ToString("0.0")<span style="font-size:10px;color:#71717a">km</span></div>
        <div class="act-stat-lbl">@(ne?"दूरी":"Distance")</div>
      </div>
      }
      @if (a.CaloriesBurned.HasValue)
      {
      <div class="act-stat">
        <div class="act-stat-val">@a.CaloriesBurned<span style="font-size:10px;color:#71717a">cal</span></div>
        <div class="act-stat-lbl">@(ne?"क्यालोरी":"Calories")</div>
      </div>
      }
    </div>
    <form method="post" action="/Activity/Delete" style="display:inline">
      <input type="hidden" name="id" value="@a.Id" />
      <button type="submit" class="act-delete" onclick="return confirm('Delete this activity?')">🗑️</button>
    </form>
  </div>
  }
  }

</div>
</div>
