@{
    ViewBag.Title = "Running Pace Calculator – ShaktiFit";
    var isAuth = Context.Session.GetString("UserId") != null;
    if (!isAuth) { ViewBag.IsLanding = true; }
    ViewBag.ActiveNav = "calculators";
    var lang = Context.Session.GetString("Lang") ?? "en";
    bool ne = lang == "ne";
    bool has = ViewBag.PaceMinKm != null;

    // Results
    int paceMinKm  = has ? (int)ViewBag.PaceMinKm  : 0;
    int paceSecKm  = has ? (int)ViewBag.PaceSecKm  : 0;
    int paceMinMi  = has ? (int)ViewBag.PaceMinMi  : 0;
    int paceSecMi  = has ? (int)ViewBag.PaceSecMi  : 0;
    double speedKph = has ? (double)ViewBag.SpeedKph : 0;
    double speedMph = has ? (double)ViewBag.SpeedMph : 0;

    // Form state
    double distVal = ViewBag.DistVal is double dv ? dv : 0;
    string unit    = ViewBag.Unit as string ?? "km";

    bool hasPred = ViewBag.Pred5k != null;
}
@await Html.PartialAsync("_CalcStyle")
<style>
  .pace-pred { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:4px; }
  .unit-toggle { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:14px; }
  .unit-btn { padding:10px; border:1.5px solid rgba(0,0,0,0.1); border-radius:12px; background:#f9f9f8; font-size:13px; font-weight:700; color:#71717a; cursor:pointer; font-family:inherit; transition:all .15s; }
  .unit-btn.active { border-color:#ef4444; background:rgba(239,68,68,0.07); color:#ef4444; }
  .pace-dual { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:16px; }
  .pace-box { background:#f9f9f8; border-radius:12px; padding:14px; text-align:center; }
  .pace-box-val { font-size:26px; font-weight:900; letter-spacing:-0.02em; color:#ef4444; }
  .pace-box-lbl { font-size:10px; color:#a1a1aa; margin-top:3px; text-transform:uppercase; letter-spacing:0.05em; }
</style>
<div class="bp"><div class="bp-inner">
  <a href="/Calculator" class="bp-back">← @(ne?"सबै क्याल्कुलेटर":"All Calculators")</a>
  <div class="bp-tag">RUN · @(ne?"दौड":"Running")</div>
  <div class="bp-title">@(ne?"दौड गति क्याल्कुलेटर":"Running Pace Calculator")</div>
  <div class="bp-sub">@(ne?"km वा miles — गति, गति र Riegel दौड अनुमान":"Supports km & miles — pace, speed + Riegel race predictions (T2 = T1 × (D2/D1)^1.06)")</div>
  <div class="bp-layout">
    <div class="bp-form">
      <div class="bp-form-title">Your Run</div>
      <form method="post" action="/Calculator/Pace">
        @Html.AntiForgeryToken()
        <input type="hidden" name="unit" id="unitInput" value="@unit" />
        <input type="hidden" name="eventVal" id="eventValInput" value="@(ViewBag.EventVal as string ?? "")" />

        <div class="bp-lbl">Distance Unit</div>
        <div class="unit-toggle">
          <button type="button" class="unit-btn @(unit=="km"?"active":"")" onclick="setUnit('km',this)">km</button>
          <button type="button" class="unit-btn @(unit=="mi"?"active":"")" onclick="setUnit('mi',this)">miles</button>
        </div>

        <div class="bp-lbl">Pick an Event <span style="font-weight:400;color:#a1a1aa">(optional)</span></div>
        <select class="bp-sel" id="eventPicker" onchange="pickEvent(this)">
          <option value="">-- or enter distance manually --</option>
          <optgroup label="Road Races (km)">
            <option value="km|0.8">800 m</option>
            <option value="km|1.5">1500 m</option>
            <option value="km|1">1K</option>
            <option value="km|5">5K</option>
            <option value="km|10">10K</option>
            <option value="km|21.0975">Half Marathon</option>
            <option value="km|42.195">Marathon</option>
          </optgroup>
          <optgroup label="Imperial Races (miles)">
            <option value="mi|1">1 Mile</option>
            <option value="mi|3.10686">5K (miles)</option>
            <option value="mi|5">5 Miles</option>
            <option value="mi|6.21371">10K (miles)</option>
            <option value="mi|10">10 Miles</option>
            <option value="mi|13.1094">Half Marathon</option>
            <option value="mi|26.2188">Marathon</option>
          </optgroup>
        </select>

        <div class="bp-lbl" id="distLabel">Distance (@(unit=="mi"?"miles":"km"))</div>
        <input class="bp-inp" type="number" name="distVal" id="distInput" placeholder="@(unit=="mi"?"e.g. 3.1":"e.g. 5")" min="0.01" max="1000" step="any" value="@(distVal>0?distVal.ToString():"")" inputmode="decimal" required />

        <div class="bp-lbl">Time</div>
        @{
            var tsParts = (ViewBag.TimeStr as string ?? "").Split(':');
            int tsH = tsParts.Length == 3 ? (int.TryParse(tsParts[0], out int ph2) ? ph2 : 0) : 0;
            int tsM = tsParts.Length >= 2 ? (int.TryParse(tsParts[tsParts.Length - 2], out int pm2) ? pm2 : 0) : 0;
            int tsS = tsParts.Length >= 1 ? (int.TryParse(tsParts[tsParts.Length - 1], out int ps2) ? ps2 : 0) : 0;
        }
        <div style="display:flex;align-items:center;gap:0;border:1.5px solid #e4e4e7;border-radius:12px;overflow:hidden;background:#fff">
          <div style="flex:1;display:flex;flex-direction:column;align-items:center;padding:10px 8px 6px">
            <input type="number" name="hours" min="0" max="23" placeholder="00" value="@(tsH > 0 ? tsH.ToString("D2") : "")"
                   style="width:100%;border:none;outline:none;font-size:20px;font-weight:700;color:#0f172a;text-align:center;background:transparent;-moz-appearance:textfield" />
            <span style="font-size:9px;font-weight:700;color:#a1a1aa;text-transform:uppercase;letter-spacing:.08em;margin-top:2px">hrs</span>
          </div>
          <span style="font-size:22px;font-weight:800;color:#d1d5db;padding-bottom:14px">:</span>
          <div style="flex:1;display:flex;flex-direction:column;align-items:center;padding:10px 8px 6px;border-left:1px solid #f0f0f0;border-right:1px solid #f0f0f0">
            <input type="number" name="minutes" min="0" max="59" placeholder="00" value="@(tsM > 0 ? tsM.ToString("D2") : "")"
                   style="width:100%;border:none;outline:none;font-size:20px;font-weight:700;color:#0f172a;text-align:center;background:transparent;-moz-appearance:textfield" required />
            <span style="font-size:9px;font-weight:700;color:#a1a1aa;text-transform:uppercase;letter-spacing:.08em;margin-top:2px">min</span>
          </div>
          <span style="font-size:22px;font-weight:800;color:#d1d5db;padding-bottom:14px">:</span>
          <div style="flex:1;display:flex;flex-direction:column;align-items:center;padding:10px 8px 6px">
            <input type="number" name="seconds" min="0" max="59" placeholder="00" value="@(tsS > 0 ? tsS.ToString("D2") : "")"
                   style="width:100%;border:none;outline:none;font-size:20px;font-weight:700;color:#0f172a;text-align:center;background:transparent;-moz-appearance:textfield" />
            <span style="font-size:9px;font-weight:700;color:#a1a1aa;text-transform:uppercase;letter-spacing:.08em;margin-top:2px">sec</span>
          </div>
        </div>
        <style>input[name=hours]::-webkit-outer-spin-button,input[name=hours]::-webkit-inner-spin-button,input[name=minutes]::-webkit-outer-spin-button,input[name=minutes]::-webkit-inner-spin-button,input[name=seconds]::-webkit-outer-spin-button,input[name=seconds]::-webkit-inner-spin-button{-webkit-appearance:none;margin:0}</style>

        <button class="bp-btn" type="submit" style="background:#ef4444">Calculate Pace</button>
      </form>
    </div>
    <div>
      @if (has) {
      <div class="bp-result" style="border-color:#ef4444">
        <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#ef4444;margin-bottom:6px">Your Pace</div>
        <div class="pace-dual">
          <div class="pace-box">
            <div class="pace-box-val">@paceMinKm:@paceSecKm.ToString("D2")</div>
            <div class="pace-box-lbl">min / km</div>
          </div>
          <div class="pace-box">
            <div class="pace-box-val">@paceMinMi:@paceSecMi.ToString("D2")</div>
            <div class="pace-box-lbl">min / mile</div>
          </div>
        </div>
        <div class="bp-stats" style="margin-top:10px">
          <div class="bp-stat"><div class="bp-stat-val">@speedKph</div><div class="bp-stat-lbl">km/h</div></div>
          <div class="bp-stat"><div class="bp-stat-val">@speedMph</div><div class="bp-stat-lbl">mph</div></div>
        </div>
      </div>

      @if (hasPred) {
      <div class="bp-card">
        <div class="bp-card-head">Race Predictions (Riegel)</div>
        <div class="bp-card-body">
          <div style="font-size:11px;color:#a1a1aa;padding:8px 0">T2 = T1 × (D2/D1)^1.06</div>
          <div class="pace-pred">
            @foreach (var r in new[]{("5K",ViewBag.Pred5k),("10K",ViewBag.Pred10k),("Half",ViewBag.PredHalf),("Marathon",ViewBag.PredMarathon)}) {
            <div class="bp-stat"><div class="bp-stat-val" style="font-size:15px;color:#ef4444">@r.Item2</div><div class="bp-stat-lbl">@r.Item1</div></div>
            }
          </div>
        </div>
      </div>
      }

      <div class="bp-card">
        <div class="bp-card-head">Pace Zones (effort guide)</div>
        <div class="bp-card-body">
          @foreach (var z in new[]{("Easy","60–70% max HR","Conversation pace, recovery"),("Aerobic","70–80% max HR","Comfortable, base building"),("Tempo","80–90% max HR","Comfortably hard, lactate threshold"),("Interval","90–95% max HR","Hard, short repeats"),("Sprint","95–100% max HR","All-out, under 60 sec")}) {
          <div class="bp-row"><span style="font-weight:700;min-width:64px">@z.Item1</span><span style="color:#a1a1aa;font-size:11px">@z.Item2</span></div>
          }
        </div>
      </div>

      } else {
      <div class="bp-empty">
        <div style="font-size:36px;font-weight:900;color:#ef4444;margin-bottom:12px">RUN</div>
        <div style="font-size:17px;font-weight:800;color:#18181b;margin-bottom:8px">Calculate Your Running Pace</div>
        <div style="font-size:13px;color:#71717a">Enter distance (km or miles) and time — get pace in both units plus race predictions</div>
      </div>
      }
    </div>
  </div>
</div></div>
<script>

function setUnit(v, btn) {
  document.getElementById('unitInput').value = v;
  document.querySelectorAll('.unit-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('distLabel').textContent = 'Distance (' + (v === 'mi' ? 'miles' : 'km') + ')';
  document.getElementById('distInput').placeholder = v === 'mi' ? 'e.g. 3.1' : 'e.g. 5';
  document.getElementById('eventPicker').value = '';
}
function pickEvent(sel) {
  if (!sel.value) { document.getElementById('eventValInput').value = ''; return; }
  var parts = sel.value.split('|');
  var u = parts[0], d = parseFloat(parts[1]);
  document.getElementById('eventValInput').value = sel.value;
  document.getElementById('unitInput').value = u;
  document.querySelectorAll('.unit-btn').forEach(b => {
    b.classList.toggle('active', b.textContent.trim() === (u === 'km' ? 'km' : 'miles'));
  });
  document.getElementById('distLabel').textContent = 'Distance (' + (u === 'mi' ? 'miles' : 'km') + ')';
  document.getElementById('distInput').placeholder = u === 'mi' ? 'e.g. 3.1' : 'e.g. 5';
  document.getElementById('distInput').value = d;
}
// Restore dropdown selection after postback
(function() {
  var saved = document.getElementById('eventValInput').value;
  if (saved) document.getElementById('eventPicker').value = saved;
})();
</script>
