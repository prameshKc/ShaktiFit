@{
    ViewBag.Title = "Protein Intake Calculator – ShaktiFit";
    var isAuth = Context.Session.GetString("UserId") != null;
    if (!isAuth) { ViewBag.IsLanding = true; }
    ViewBag.ActiveNav = "calculators";
    var lang = Context.Session.GetString("Lang") ?? "en";
    bool ne = lang == "ne";
    bool has = ViewBag.MinG != null;
    int minG = has ? (int)ViewBag.MinG : 0;
    int maxG = has ? (int)ViewBag.MaxG : 0;
    int midG = has ? (int)ViewBag.MidG : 0;
    double minR = has ? (double)ViewBag.MinRate : 0;
    double maxR = has ? (double)ViewBag.MaxRate : 0;
    double weight = ViewBag.Weight is double w ? w : 0;
    string activity = ViewBag.Activity as string ?? "moderate";
    string goal = ViewBag.Goal as string ?? "maintain";

    var actOpts = new[]{("sedentary","🪑",ne?"बस्ने (व्यायाम छैन)":"Sedentary (no exercise)"),("light","🚶",ne?"हल्का गतिविधि":"Light activity"),("moderate","🏃",ne?"मध्यम गतिविधि":"Moderate activity"),("endurance","🚴",ne?"धीरज खेलाडी":"Endurance athlete"),("athlete","💪",ne?"शक्ति खेलाडी":"Strength athlete")};
    var goalOpts = new[]{("maintain","⚖️",ne?"तौल कायम राख्ने":"Maintain weight"),("lose","📉",ne?"तौल घटाउने":"Lose weight"),("muscle","💪",ne?"मांसपेशी बनाउने":"Build muscle")};
    var actSb = new System.Text.StringBuilder("<select class=\"bp-sel\" name=\"activity\">");
    foreach (var o in actOpts) actSb.Append($"<option value=\"{o.Item1}\"{(activity==o.Item1?" selected":"")}>{o.Item2} {o.Item3}</option>");
    actSb.Append("</select>");
    var goalSb = new System.Text.StringBuilder("<select class=\"bp-sel\" name=\"goal\">");
    foreach (var o in goalOpts) goalSb.Append($"<option value=\"{o.Item1}\"{(goal==o.Item1?" selected":"")}>{o.Item2} {o.Item3}</option>");
    goalSb.Append("</select>");
}
@await Html.PartialAsync("_CalcStyle")
<div class="bp"><div class="bp-inner">
  <a href="/Calculator" class="bp-back">← @(ne?"सबै क्याल्कुलेटर":"All Calculators")</a>
  <div class="bp-tag">💪 @(ne?"पोषण":"Nutrition")</div>
  <div class="bp-title">@(ne?"प्रोटिन सेवन क्याल्कुलेटर":"Protein Intake Calculator")</div>
  <div class="bp-sub">@(ne?"ISSN र ACSM दिशानिर्देशहरूमा आधारित — गतिविधि र लक्ष्य अनुसार दैनिक प्रोटिन":"Based on ISSN & ACSM position stands — daily protein tailored to your activity and goal")</div>
  <div class="bp-layout">
    <div class="bp-form">
      <div class="bp-form-title">📋 @(ne?"तपाईंको जानकारी":"Your Details")</div>
      <form method="post" action="/Calculator/Protein">
        @Html.AntiForgeryToken()
        <div class="bp-lbl">@(ne?"तौल (kg)":"Body Weight (kg)")</div>
        <input class="bp-inp" type="number" name="weight" placeholder="e.g. 70" min="30" max="200" step="0.1" value="@(weight>0?weight.ToString():"")" inputmode="decimal" required />
        <div class="bp-lbl">@(ne?"गतिविधि स्तर":"Activity Level")</div>
        @Html.Raw(actSb.ToString())
        <div class="bp-lbl">@(ne?"लक्ष्य":"Your Goal")</div>
        @Html.Raw(goalSb.ToString())
        <button class="bp-btn" type="submit">💪 @(ne?"प्रोटिन गणना गर्नुहोस्":"Calculate Protein")</button>
      </form>
    </div>
    <div>
      @if (has) {
      <div class="bp-result" style="border-color:#8b5cf6">
        <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#8b5cf6;margin-bottom:6px">@(ne?"दैनिक प्रोटिन":"Daily Protein")</div>
        <div class="bp-result-num" style="color:#8b5cf6">@midG<span style="font-size:28px">g</span></div>
        <div style="font-size:12px;color:#a1a1aa;margin-top:4px">@minG–@maxG g/day (@minR–@maxR g/kg)</div>
        <div class="bp-stats" style="margin-top:16px">
          <div class="bp-stat"><div class="bp-stat-val">@minG g</div><div class="bp-stat-lbl">@(ne?"न्यूनतम":"Minimum")</div></div>
          <div class="bp-stat"><div class="bp-stat-val">@midG g</div><div class="bp-stat-lbl">@(ne?"लक्ष्य":"Target")</div></div>
          <div class="bp-stat"><div class="bp-stat-val">@maxG g</div><div class="bp-stat-lbl">@(ne?"अधिकतम":"Maximum")</div></div>
        </div>
      </div>
      <div class="bp-card">
        <div class="bp-card-head">🍗 @(ne?"प्रोटिन स्रोतहरू":"Protein Sources")</div>
        <div class="bp-card-body">
          @foreach (var f in new[]{("Chicken breast 100g","31g protein"),("Eggs (2 large)","12g protein"),("Greek yogurt 150g","15g protein"),("Lentils cooked 100g","9g protein"),("Tofu 100g","8g protein"),("Whey protein 1 scoop","25g protein")}) {
          <div class="bp-row"><span>@f.Item1</span><strong style="color:#8b5cf6">@f.Item2</strong></div>
          }
        </div>
      </div>
      } else {
      <div class="bp-empty"><div style="font-size:52px;margin-bottom:16px">💪</div><div style="font-size:17px;font-weight:800;color:#18181b;margin-bottom:8px">@(ne?"आफ्नो प्रोटिन लक्ष्य थाहा पाउनुहोस्":"Find Your Protein Target")</div><div style="font-size:13px;color:#71717a">@(ne?"तपाईंको गतिविधि र लक्ष्य अनुसार सटीक प्रोटिन सिफारिस":"Personalized protein recommendation based on your activity and goal")</div></div>
      }
    </div>
  </div>
</div></div>
