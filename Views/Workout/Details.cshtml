@model FitForgeAI.Models.Workout
@{
    var w = Model;
    ViewBag.Title = $"{w.Name} – ShaktiFit";
    ViewBag.ActiveNav = "workout";
    var lang = Context.Session.GetString("Lang") ?? "en";
    bool ne = lang == "ne";
    string typeColor = w.Type switch {
        "Strength" => "#ef4444", "Cardio" => "#f97316", "Running" => "#3b82f6",
        "Hybrid" => "#8b5cf6", "Mobility" => "#06b6d4", _ => "#22c55e"
    };
    string typeIcon = w.Type switch {
        "Strength" => "🏋️", "Cardio" => "🔥", "Running" => "🏃",
        "Hybrid" => "🦸", "Mobility" => "🧘", _ => "💪"
    };
    string diffColor = w.FitnessLevel switch { "Beginner" => "#16a34a", "Advanced" => "#dc2626", _ => "#92400e" };
    string diffBg = w.FitnessLevel switch { "Beginner" => "#f0fdf4", "Advanced" => "#fef2f2", _ => "#fefce8" };
}

<style>
.wd-page { background:#f8faf8; min-height:100vh; }
.wd-wrap { max-width:1000px; margin:0 auto; padding:24px 20px 100px; }
.wd-back { display:inline-flex; align-items:center; gap:6px; color:#64748b; font-size:13px; font-weight:600; text-decoration:none; margin-bottom:20px; transition:color .15s; }
.wd-back:hover { color:#16a34a; }

/* Hero Card */
.wd-hero { background:linear-gradient(135deg,#0f1f0f 0%,#1a3a1a 55%,#16a34a 100%); border-radius:20px; padding:30px 34px; margin-bottom:22px; position:relative; overflow:hidden; }
.wd-hero::before { content:''; position:absolute; top:-40px; right:-40px; width:200px; height:200px; background:rgba(34,197,94,0.1); border-radius:50%; }
.wd-hero-row { display:flex; align-items:flex-start; gap:20px; flex-wrap:wrap; position:relative; }
.wd-hero-icon { font-size:56px; flex-shrink:0; }
.wd-hero-info { flex:1; }
.wd-hero-badges { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:10px; }
.wd-badge { padding:5px 13px; border-radius:999px; font-size:11px; font-weight:700; }
.wd-hero-name { font-size:26px; font-weight:900; color:#f0fdf4; letter-spacing:-0.02em; margin-bottom:8px; }
.wd-hero-desc { font-size:14px; color:rgba(240,253,244,0.7); margin-bottom:16px; line-height:1.55; }
.wd-hero-meta { display:flex; gap:12px; flex-wrap:wrap; }
.wd-meta-pill { padding:6px 14px; background:rgba(255,255,255,0.1); border-radius:999px; font-size:13px; font-weight:600; color:rgba(240,253,244,0.85); }

/* Layout */
.wd-layout { display:grid; grid-template-columns:1fr 280px; gap:20px; align-items:start; }

/* Exercise table card */
.wd-card { background:#fff; border:1.5px solid rgba(0,0,0,0.07); border-radius:18px; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,0.04); }
.wd-card-head { padding:16px 20px; border-bottom:1px solid rgba(0,0,0,0.06); font-size:14px; font-weight:800; color:#0f172a; display:flex; align-items:center; gap:8px; }
.wd-card-body { padding:0; }

.ex-table-new { width:100%; border-collapse:collapse; font-size:13px; }
.ex-table-new th { padding:11px 16px; text-align:left; font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:0.08em; color:#94a3b8; background:#fafbff; border-bottom:1px solid rgba(0,0,0,0.06); }
.ex-table-new td { padding:13px 16px; border-bottom:1px solid rgba(0,0,0,0.04); color:#374151; }
.ex-table-new tr:last-child td { border-bottom:none; }
.ex-table-new tr:hover td { background:#f8faf8; }
.ex-num { color:#94a3b8; font-weight:600; }
.ex-name-link { font-weight:700; color:#0f172a; }
.ex-view-link { font-size:11px; color:#22c55e; font-weight:600; text-decoration:none; margin-left:6px; padding:2px 8px; background:#f0fdf4; border-radius:999px; }
.ex-reps { color:#22c55e; font-weight:700; }

/* Side cards */
.wd-action-card { background:#fff; border:1.5px solid rgba(0,0,0,0.07); border-radius:18px; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,0.04); margin-bottom:14px; }
.wd-complete-btn { width:100%; padding:13px; background:linear-gradient(135deg,#22c55e,#16a34a); color:#fff; border:none; border-radius:10px; font-size:14px; font-weight:700; cursor:pointer; margin-bottom:8px; transition:opacity .15s; }
.wd-complete-btn:hover { opacity:.9; }
.wd-back-btn { width:100%; padding:12px; background:#f8faf8; border:1.5px solid rgba(0,0,0,0.08); border-radius:10px; font-size:14px; font-weight:600; color:#374151; text-decoration:none; display:flex; align-items:center; justify-content:center; gap:6px; }
.wd-back-btn:hover { border-color:rgba(34,197,94,0.3); color:#16a34a; }

/* Stats */
.wd-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; padding:16px; }
.wd-stat { text-align:center; background:#f8faf8; border-radius:12px; padding:12px 8px; }
.wd-stat-val { font-size:20px; font-weight:900; color:#0f172a; }
.wd-stat-lbl { font-size:10px; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:.07em; margin-top:2px; }

@@media(max-width:768px){
  .wd-layout { grid-template-columns:1fr; }
  .wd-hero-name { font-size:22px; }
  .wd-wrap { padding:16px 14px 100px; }
}
</style>

<div class="wd-page">
<div class="wd-wrap">

  <a href="/Workout" class="wd-back">← @(ne?"सबै योजना":"All Plans")</a>

  <!-- Hero -->
  <div class="wd-hero">
    <div class="wd-hero-row">
      <div class="wd-hero-icon">@typeIcon</div>
      <div class="wd-hero-info">
        <div class="wd-hero-badges">
          <span class="wd-badge" style="background:rgba(255,255,255,0.15);color:#f0fdf4">@w.Type</span>
          <span class="wd-badge" style="background:@diffBg;color:@diffColor">@w.FitnessLevel</span>
        </div>
        <div class="wd-hero-name">@(ne && !string.IsNullOrEmpty(w.NameNepali) ? w.NameNepali : w.Name)</div>
        <div class="wd-hero-desc">@w.Description</div>
        <div class="wd-hero-meta">
          <span class="wd-meta-pill">⏱️ @w.DurationMinutes @(ne?"मिनेट":"min")</span>
          <span class="wd-meta-pill">🔥 ~@w.EstimatedCalories kcal</span>
          <span class="wd-meta-pill">💪 @w.Exercises.Count @(ne?"व्यायाम":"exercises")</span>
        </div>
      </div>
    </div>
  </div>

  <div class="wd-layout">

    <!-- Exercise Table -->
    <div class="wd-card">
      <div class="wd-card-head">💪 @(ne?"व्यायाम सूची":"Exercise List")</div>
      <div class="wd-card-body">
        <table class="ex-table-new">
          <thead>
            <tr>
              <th>#</th>
              <th>@(ne?"व्यायाम":"Exercise")</th>
              <th>@(ne?"सेट":"Sets")</th>
              <th>@(ne?"रेप्स":"Reps")</th>
              <th>@(ne?"आराम":"Rest")</th>
              <th>@(ne?"नोट":"Notes")</th>
            </tr>
          </thead>
          <tbody>
            @{ int i = 1; }
            @foreach (var ex in w.Exercises)
            {
            <tr>
              <td class="ex-num">@(i++)</td>
              <td>
                <span class="ex-name-link">@ex.ExerciseName</span>
                @if (!string.IsNullOrEmpty(ex.ExerciseId))
                { <a href="/Exercise/Details/@ex.ExerciseId" class="ex-view-link">@(ne?"हेर्नुहोस्":"view")</a> }
              </td>
              <td style="font-weight:700">@ex.Sets</td>
              <td class="ex-reps">@ex.Reps</td>
              <td style="color:#64748b">@ex.RestSeconds s</td>
              <td style="color:#94a3b8;font-size:12px">@(ex.Notes ?? "")</td>
            </tr>
            }
          </tbody>
        </table>
      </div>
    </div>

    <!-- Right side -->
    <div>
      <!-- Stats -->
      <div class="wd-action-card" style="margin-bottom:14px">
        <div class="wd-card-head">📊 @(ne?"सारांश":"Summary")</div>
        <div class="wd-stats">
          <div class="wd-stat">
            <div class="wd-stat-val">@w.DurationMinutes</div>
            <div class="wd-stat-lbl">@(ne?"मिनेट":"Minutes")</div>
          </div>
          <div class="wd-stat">
            <div class="wd-stat-val" style="color:#ef4444">@w.EstimatedCalories</div>
            <div class="wd-stat-lbl">@(ne?"kcal":"Calories")</div>
          </div>
          <div class="wd-stat">
            <div class="wd-stat-val" style="color:#22c55e">@w.Exercises.Count</div>
            <div class="wd-stat-lbl">@(ne?"व्यायाम":"Exercises")</div>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="wd-action-card">
        <div class="wd-card-head">🚀 @(ne?"सुरु गर्नुहोस्":"Start Workout")</div>
        <div style="padding:16px">
          <form method="post" action="/Dashboard/CompleteWorkout">
            <input type="hidden" name="workoutId" value="@w.Id" />
            <input type="hidden" name="duration" value="@w.DurationMinutes" />
            <button type="submit" class="wd-complete-btn">✅ @(ne?"व्यायाम सम्पन्न":"Mark Complete")</button>
          </form>
          <a href="/Workout" class="wd-back-btn">← @(ne?"सबै योजनाहरू":"All Plans")</a>
        </div>
      </div>

      @if (w.Goals.Any())
      {
      <div class="wd-action-card" style="margin-top:14px">
        <div class="wd-card-head">🎯 @(ne?"लक्ष्य":"Goals")</div>
        <div style="padding:14px 16px;display:flex;flex-wrap:wrap;gap:6px">
          @foreach (var g in w.Goals)
          { <span style="padding:5px 12px;background:#f0fdf4;border:1px solid rgba(34,197,94,0.2);border-radius:999px;font-size:12px;font-weight:600;color:#16a34a">@g</span> }
        </div>
      </div>
      }
    </div>

  </div>
</div>
</div>
