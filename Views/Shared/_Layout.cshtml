        @foreach (var c in new[]{
            ("green","#22c55e","🟢 Green"),("yellow","#f5c542","☀️ Yellow"),
            ("blue","#3b82f6","🔵 Blue"),("purple","#a855f7","🟣 Purple"),
            ("red","#ef4444","🔴 Red"),("orange","#f97316","🟠 Orange")
        })
        {
        <button onclick="setAccent('@c.Item1')" data-accent="@c.Item1"
            style="padding:10px 6px;border-radius:10px;border:2px solid rgba(255,255,255,0.08);background:@(c.Item2)18;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:4px;transition:all 0.15s"
            class="accent-btn">
            <div style="width:28px;height:28px;background:@c.Item2;border-radius:7px"></div>
            <div style="font-size:10px;font-weight:700;color:#475569">@c.Item3.Split(' ')[1]</div>
        </button>
        }
    </div>
    <!-- Dark/Light mode -->
    <div style="font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:12px">App Mode</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:24px">
        <button onclick="setMode('dark')" id="modeDark" style="padding:12px;border-radius:10px;border:2px solid rgba(245,197,66,0.4);background:#0d0b09;color:#f5f0e8;font-size:13px;font-weight:700;cursor:pointer">🌙 Dark</button>
        <button onclick="setMode('light')" id="modeLight" style="padding:12px;border-radius:10px;border:2px solid rgba(255,255,255,0.1);background:#f0ece4;color:#1c1917;font-size:13px;font-weight:700;cursor:pointer">☀️ Light</button>
    </div>
    <div style="font-size:12px;color:#94a3b8;line-height:1.6;padding:12px;background:#f8faf8;border-radius:10px;border:1px solid rgba(0,0,0,0.07)">
        💡 Theme settings are saved automatically and persist across sessions.
    </div>
</div>

<script src="~/js/fitforge.js" asp-append-version="true"></script>
<script>
// ── DRAWER ──
function toggleCalcMenu(e) {
  e.stopPropagation();
  document.getElementById('calcDropdown')?.classList.toggle('open');
}
document.addEventListener('click', function() {
  document.getElementById('calcDropdown')?.classList.remove('open');
});
function openDrawer() {
  document.getElementById('sidebarDrawer')?.classList.add('open');
  document.getElementById('drawerOverlay')?.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeDrawer() {
  document.getElementById('sidebarDrawer')?.classList.remove('open');
  document.getElementById('drawerOverlay')?.classList.remove('open');
  document.body.style.overflow = '';
}
function openGuestMenu() {
  document.getElementById('guestDrawer')?.classList.add('open');
  document.getElementById('guestOverlay')?.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeGuestMenu() {
  document.getElementById('guestDrawer')?.classList.remove('open');
  document.getElementById('guestOverlay')?.classList.remove('open');
  document.body.style.overflow = '';
}
// ── THEME PANEL ──
function openTheme() {
  document.getElementById('themePanel').classList.add('open');
  document.getElementById('themeOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeTheme() {
  document.getElementById('themePanel').classList.remove('open');
  document.getElementById('themeOverlay').classList.remove('open');
  document.body.style.overflow = '';
}
// ── ACCENT ──
function setAccent(name) {
  document.documentElement.setAttribute('data-accent', name);
  localStorage.setItem('sf-accent', name);
  document.querySelectorAll('.accent-btn').forEach(b => {
    b.style.borderColor = b.dataset.accent === name ? 'rgba(245,240,232,0.6)' : 'rgba(255,255,255,0.08)';
  });
}
// ── MODE ──
function setMode(mode) {
  document.documentElement.setAttribute('data-theme', mode);
  localStorage.setItem('sf-mode', mode);
  document.getElementById('modeDark').style.borderColor = mode==='dark' ? 'rgba(245,197,66,0.5)' : 'rgba(255,255,255,0.1)';
  document.getElementById('modeLight').style.borderColor = mode==='light' ? 'rgba(28,25,23,0.5)' : 'rgba(255,255,255,0.1)';
}
// ── RESTORE SAVED THEME ──
(function() {
  const accent = localStorage.getItem('sf-accent') || 'green';
  // v3 migration: force light mode as default for all users
  if (!localStorage.getItem('sf-v3')) {
    localStorage.setItem('sf-mode', 'light');
    localStorage.setItem('sf-accent', 'green');
    localStorage.removeItem('sf-v2');
    localStorage.setItem('sf-v3', '1');
  }
  const mode = localStorage.getItem('sf-mode') || 'light';
  document.documentElement.setAttribute('data-accent', localStorage.getItem('sf-accent') || 'green');
  document.documentElement.setAttribute('data-theme',  mode);
})();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
