@section Scripts {
<script>
function toggleHomeCalc(e) {
  e.stopPropagation();
  document.getElementById('calcDropdownHome')?.classList.toggle('open');
}
document.addEventListener('click', function() {
  document.getElementById('calcDropdownHome')?.classList.remove('open');
});
const bmiData = {
  en: [
    {max:18.5,label:'Underweight',color:'#60a5fa'},
    {max:25,label:'Normal Weight',color:'#4ade80'},
    {max:30,label:'Overweight',color:'#fbbf24'},
    {max:999,label:'Obese',color:'#f87171'}
  ],
  ne: [
    {max:18.5,label:'कम तौल',color:'#60a5fa'},
    {max:25,label:'सामान्य तौल',color:'#4ade80'},
    {max:30,label:'अधिक तौल',color:'#fbbf24'},
    {max:999,label:'मोटोपन',color:'#f87171'}
  ]
};
const pageLang = '@lang';
function calcBmi() {
  const h = parseFloat(document.getElementById('bH').value);
  const w = parseFloat(document.getElementById('bW').value);
  const valEl = document.getElementById('bVal');
  const catEl = document.getElementById('bCat');
  if (!h || !w || h < 100 || w < 20) {
    valEl.textContent = '—'; valEl.style.color = '#22c55e';
    catEl.textContent = pageLang === 'ne' ? 'उचाइ र तौल भर्नुहोस्' : 'Enter height & weight above';
    catEl.style.color = '#94a3b8'; return;
  }
  const bmi = Math.round(w / Math.pow(h/100,2) * 10) / 10;
  const cats = bmiData[pageLang === 'ne' ? 'ne' : 'en'];
  const cat = cats.find(c => bmi < c.max) || cats[cats.length-1];
  valEl.textContent = bmi.toFixed(1);
  valEl.style.color = cat.color;
  catEl.textContent = cat.label;
  catEl.style.color = cat.color;
}
</script>
}
