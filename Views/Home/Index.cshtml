              <a href="/Calculator/Protein" class="calc-menu-item"><div class="calc-menu-icon" style="background:#f5f3ff;color:#7c3aed"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="8" width="3" height="4" rx="1"/><rect x="16" y="8" width="3" height="4" rx="1"/><rect x="4" y="7" width="3" height="6" rx="1"/><rect x="13" y="7" width="3" height="6" rx="1"/><line x1="7" y1="10" x2="13" y2="10" stroke-width="2.5"/></svg></div><div><div>Protein Intake</div><div style="font-size:11px;color:#94a3b8;font-weight:500">ISSN/ACSM guidelines</div></div></a>
