              <a href="/Calculator/OneRepMax" class="calc-menu-item"><div class="calc-menu-icon" style="background:#fff7ed;color:#ea580c"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="8" width="2" height="4" rx="0.5"/><rect x="17" y="8" width="2" height="4" rx="0.5"/><rect x="3" y="7" width="2.5" height="6" rx="0.5"/><rect x="14.5" y="7" width="2.5" height="6" rx="0.5"/><line x1="5.5" y1="10" x2="14.5" y2="10" stroke-width="2.5"/></svg></div><div><div>1 Rep Max</div><div style="font-size:11px;color:#94a3b8;font-weight:500">4 formulas averaged</div></div></a>
