        <a href="/Health" class="app-nav-link">@(ne?"स्वास्थ्य":"Health")</a>
        <a href="/Running" class="app-nav-link">@(ne?"दौड":"Running")</a>
        <div class="calc-dropdown" id="calcDropdownHome">
          <button class="calc-dropdown-btn" style="font-size:13px" onclick="toggleHomeCalc(event)">
